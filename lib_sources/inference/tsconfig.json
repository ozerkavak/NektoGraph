        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist",
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
