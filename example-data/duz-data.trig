@prefix : <http://www.40nodes.net/ontologies/ngo#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.40nodes.net/ontologies/ngo/data/main-data> {

    ### ==========================================
    ### 1. LOKASYONLAR (PLACES)
    ### ==========================================

    # Ülkeler — hiyerarşinin kökleri, isWithin triple'ı yok
    :id_xL8a2B a :Country ;
        rdfs:label "Turkey"@en, "Türkiye"@tr .

    :id_yT4k9P a :Country ;
        rdfs:label "Germany"@en, "Almanya"@tr .

    :id_mN1b7C a :Country ;
        rdfs:label "United States"@en, "ABD"@tr .

    # Bölgeler → Ülke
    # Transitivity: Region isWithin Country (doğrudan)
    :id_qR5v3Z a :Region ;
        rdfs:label "Marmara Region"@en, "Marmara Bölgesi"@tr ;
        :isWithin :id_xL8a2B .

    # İller → Ülke
    # Reasoner: Province isWithin Country (doğrudan + isWithin Region isWithin Country)
    # Doğrudan Country bağı yazılıyor; Region bağı biliniyorsa o da eklenebilir
    :id_kL9m4X a :Province ;
        rdfs:label "Isparta"@en, "Isparta"@tr ;
        :isWithin :id_xL8a2B .

    :id_jH2p8W a :Province ;
        rdfs:label "Antalya"@en, "Antalya"@tr ;
        :isWithin :id_xL8a2B .

    :id_vC7d1F a :Province ;
        rdfs:label "Istanbul"@en, "İstanbul"@tr ;
        :isWithin :id_qR5v3Z .     # İstanbul → Marmara → Türkiye (transitif)

    :id_bN3x5G a :Province ;
        rdfs:label "Kirklareli"@en, "Kırklareli"@tr ;
        :isWithin :id_qR5v3Z .     # Kırklareli → Marmara → Türkiye (transitif)

    :id_pQ6t2Y a :Province ;
        rdfs:label "Aydin"@en, "Aydın"@tr ;
        :isWithin :id_xL8a2B .

    # İlçeler → İl → (Bölge →) Ülke (hepsi transitif)
    :id_zW4f9S a :District ;
        rdfs:label "Kusadasi"@en, "Kuşadası"@tr ;
        :isWithin :id_pQ6t2Y .     # Kuşadası → Aydın → Türkiye (transitif)

    :id_rM1y6H a :District ;
        rdfs:label "Maltepe"@en, "Maltepe"@tr ;
        :isWithin :id_vC7d1F .     # Maltepe → İstanbul → Marmara → Türkiye (transitif)

    :id_hK8n3D a :District ;
        rdfs:label "Kirklareli Central"@en, "Kırklareli Merkez"@tr ;
        :isWithin :id_bN3x5G .     # Kırklareli Merkez → Kırklareli → Marmara → Türkiye (transitif)

    ### ==========================================
    ### 2. TEŞKİLAT BİRİMLERİ (ORGANIZATION UNITS)
    ### ==========================================

    # KURAL (e) UYGULAMASI: :Headquarters ve :DepartmentOfOrganization sınıfları kaldırıldı.
    # Bu birimler artık :OfficialUnit instance'ları olarak tanımlanmaktadır.
    # KURAL (c): :representsLocation'ın domain'i :OrganizationUnit → rdf:type zaten var.
    # KURAL (c): :isSubUnitOf'un domain'i :OrganizationUnit → rdf:type zaten var.
    #
    # isUnderJurisdictionOf: reasoner olmayan ortamlar için kritik zincir bağları
    # doğrudan yazılmıştır. Reasoner varsa bu triple'lar otomatik çıkarılır.

    :id_uH4q1L a :OfficialUnit ;
        rdfs:label "NGO Headquarters"@en, "NGO Genel Merkez"@tr ;
        :representsLocation :id_xL8a2B .

    # Teşkilatlanma Bşk. → Genel Merkez
    :id_uT7z9K a :OfficialUnit ;
        rdfs:label "Department of Organization"@en, "Teşkilatlanma Başkanlığı"@tr ;
        :isSubUnitOf :id_uH4q1L ;
        :isUnderJurisdictionOf :id_uH4q1L .

    # KURAL (c): :reportsTo'nun domain'i :OrganizationUnit → rdf:type zaten var.
    # Almanya Temsilciliği → Teşkilatlanma Bşk. → Genel Merkez
    :id_uD2m5N a :CountryRepresentation ;
        rdfs:label "Germany Representation"@en, "Almanya Temsilciliği"@tr ;
        :representsLocation :id_yT4k9P ;
        :reportsTo :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uH4q1L .

    # ABD Temsilciliği → Teşkilatlanma Bşk. → Genel Merkez
    :id_uA8p3R a :CountryRepresentation ;
        rdfs:label "USA Representation"@en, "ABD Temsilciliği"@tr ;
        :representsLocation :id_mN1b7C ;
        :reportsTo :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uH4q1L .

    # Marmara Bölge Temsilciliği → Teşkilatlanma Bşk. → Genel Merkez
    :id_uM6b1V a :RegionalRepresentation ;
        rdfs:label "Marmara Regional Representation"@en, "Marmara Bölge Temsilciliği"@tr ;
        :representsLocation :id_qR5v3Z ;
        :reportsTo :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uT7z9K ;
        :isUnderJurisdictionOf :id_uH4q1L .

