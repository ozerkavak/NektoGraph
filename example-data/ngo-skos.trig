###############################################################################
#  NGO SKOS VOCABULARY  —  ngo-skos.trig
#  Format   : TriG (RDF 1.2 / RDF-Star)
#  Version  : 0.1.0
#  Bağımlılık: ngo-ontology.trig
#
#  İçerik:
#    Graph S1 — AdministrativeLevelScheme   (ülkeden bağımsız kademe tipleri)
#    Graph S2 — Turkey AdminArea Scheme     (TR coğrafi hiyerarşi + bölgeler)
#    Graph S3 — TopicScheme                 (NGO konu sınıflandırması)
#    Graph S4 — MembershipLifecycleScheme   (üyelik yaşam döngüsü notları)
###############################################################################

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix ngo:   <https://w3id.org/ngo/ontology#> .
@prefix ngos:  <https://w3id.org/ngo/skos/> .
@prefix ngog:  <https://w3id.org/ngo/graph/> .
@prefix level: <https://w3id.org/ngo/skos/level/> .
@prefix tr:    <https://w3id.org/ngo/skos/tr/> .
@prefix topic: <https://w3id.org/ngo/skos/topic/> .

###############################################################################
#  GRAPH S1 — Administrative Level Scheme
#  Ülkeden bağımsız idari kademe TİPLERİ.
#  Her ülke kendi bölgesel ConceptScheme'inde bu seviyelere referans verir.
###############################################################################

ngog:skos-admin-levels {

    ngos:AdministrativeLevelScheme
        a skos:ConceptScheme ;
        skos:prefLabel  "İdari Kademe Şeması"@tr ,
                        "Administrative Level Scheme"@en ;
        skos:definition "NGO teşkilat birimlerinin karşılık geldiği idari kademe tiplerini tanımlar. Belirli ülkelerin coğrafi alanları bu şemaya skos:broader ile bağlanır."@tr ,
                        "Defines the types of administrative levels to which NGO territorial units correspond. Specific country geographic areas link to this scheme via skos:broader."@en ;
        dct:created     "2025-04-24"^^xsd:date ;
        skos:hasTopConcept level:National .

    # ── Üst Kavram ────────────────────────────────────────────────────────────

    level:National
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:topConceptOf ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Ülke Düzeyi"@tr , "National Level"@en ;
        skos:notation   "L0" ;
        skos:narrower   level:Region , level:State .

    # ── Bölgesel Düzey ────────────────────────────────────────────────────────

    level:Region
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Bölge"@tr , "Region"@en ;
        skos:notation   "L1-R" ;
        skos:broader    level:National ;
        skos:narrower   level:Province ;
        skos:scopeNote  "Türkiye'de istatistiki bölge (NUTS-1/2), ABD'de Census Region gibi üst coğrafi birimler."@tr ,
                        "Corresponds to statistical regions (NUTS-1/2 in TR, Census Region in US) above province level."@en .

    level:State
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Eyalet / Federe Birim"@tr , "State / Federated Unit"@en ;
        skos:notation   "L1-S" ;
        skos:broader    level:National ;
        skos:narrower   level:County ;
        skos:scopeNote  "Federal yapılarda eyalet düzeyi (ABD, Almanya vb.)."@tr ,
                        "State level in federal structures (USA, Germany, etc.)."@en .

    # ── İl / Province ─────────────────────────────────────────────────────────

    level:Province
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "İl / Vilayet"@tr , "Province"@en ;
        skos:notation   "L2" ;
        skos:broader    level:Region ;
        skos:narrower   level:District ;
        skos:scopeNote  "Türkiye il, Fransa département, Japonya prefecture gibi ikinci düzey idari birimler."@tr ,
                        "Second-level administrative units: province in TR, département in FR, prefecture in JP."@en .

    level:County
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "İlçe / County"@tr , "County"@en ;
        skos:notation   "L2-C" ;
        skos:broader    level:State ;
        skos:narrower   level:Municipality ;
        skos:scopeNote  "ABD county, İngiltere county gibi eyalet altı birimler."@tr ,
                        "Sub-state units: US county, UK county."@en .

    # ── İlçe / District ───────────────────────────────────────────────────────

    level:District
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "İlçe"@tr , "District"@en ;
        skos:notation   "L3" ;
        skos:broader    level:Province ;
        skos:narrower   level:Neighbourhood ;
        skos:scopeNote  "Türkiye ilçesi gibi il altı idari birimler."@tr ,
                        "Sub-province units such as Turkish district (ilçe)."@en .

    level:Municipality
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Belediye / Municipality"@tr , "Municipality"@en ;
        skos:notation   "L3-M" ;
        skos:broader    level:County ;
        skos:narrower   level:Township ;
        skos:scopeNote  "ABD municipality, Almanya Gemeinde gibi yerel yönetim birimleri."@tr ,
                        "Local government units: US municipality, German Gemeinde."@en .

    # ── Mahalle / Neighbourhood ───────────────────────────────────────────────

    level:Neighbourhood
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Mahalle / Köy"@tr , "Neighbourhood / Village"@en ;
        skos:notation   "L4" ;
        skos:broader    level:District ;
        skos:scopeNote  "Türkiye'de mahalle veya köy düzeyi."@tr ,
                        "Neighbourhood or village level in Turkey."@en .

    level:Township
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Township"@tr , "Township"@en ;
        skos:notation   "L4-T" ;
        skos:broader    level:Municipality ;
        skos:scopeNote  "ABD township gibi belediye altı birimler."@tr ,
                        "Sub-municipal units such as US township."@en .

    # ── Uluslararası / Yurt Dışı ──────────────────────────────────────────────

    level:ForeignRepresentationLevel
        a skos:Concept ;
        skos:inScheme   ngos:AdministrativeLevelScheme ;
        skos:prefLabel  "Yurt Dışı Temsilcilik"@tr , "Foreign Representation"@en ;
        skos:notation   "L-INT" ;
        skos:broader    level:National ;
        skos:scopeNote  "Türkiye dışındaki ülkelerde kurulan NGO temsilcilikleri."@tr ,
                        "NGO representations established in countries outside Turkey."@en .
}

###############################################################################
#  GRAPH S2 — Turkey Administrative Area Scheme
#  Türkiye'nin NUTS-1/2 bölgeleri, 81 il ve seçili ilçe örnekleri.
#  Gerçek kullanımda tüm ilçeler ve mahalleler bu şemaya eklenir.
###############################################################################

ngog:skos-tr-areas {

    tr:TurkeyAdminScheme
        a skos:ConceptScheme ;
        skos:prefLabel  "Türkiye İdari Bölgeler Şeması"@tr ,
                        "Turkey Administrative Areas Scheme"@en ;
        skos:definition "Türkiye'nin NUTS-1 istatistiki bölgeleri, iller ve ilçelerini kapsayan coğrafi hiyerarşi. ngo:TerritorialUnit'lerin ngo:administrativeArea property'si bu şemaya referans verir."@tr ,
                        "Geographic hierarchy covering Turkey's NUTS-1 statistical regions, provinces and districts. Referenced by ngo:administrativeArea property of ngo:TerritorialUnit instances."@en ;
        dct:created     "2025-04-24"^^xsd:date ;
        skos:hasTopConcept tr:Turkey .

    # ── Türkiye (ülke) ────────────────────────────────────────────────────────

    tr:Turkey
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:topConceptOf tr:TurkeyAdminScheme ;
        skos:prefLabel  "Türkiye"@tr , "Turkey"@en ;
        skos:notation   "TR" ;
        skos:exactMatch <http://www.wikidata.org/entity/Q43> ;
        ngo:administrativeLevel level:National ;
        skos:narrower
            tr:TR-NUTS1-1 , tr:TR-NUTS1-2 , tr:TR-NUTS1-3 ,
            tr:TR-NUTS1-4 , tr:TR-NUTS1-5 , tr:TR-NUTS1-6 ,
            tr:TR-NUTS1-7 , tr:TR-NUTS1-8 , tr:TR-NUTS1-9 ,
            tr:TR-NUTS1-10 , tr:TR-NUTS1-11 , tr:TR-NUTS1-12 .

    # ── NUTS-1 Bölgeleri ──────────────────────────────────────────────────────

    tr:TR-NUTS1-1
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "İstanbul"@tr , "Istanbul"@en ;
        skos:notation   "TR1" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-istanbul .

    tr:TR-NUTS1-2
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Batı Marmara"@tr , "West Marmara"@en ;
        skos:notation   "TR2" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-tekirdag , tr:prov-edirne , tr:prov-kirklareli ,
                        tr:prov-balikesir , tr:prov-canakkale .

    tr:TR-NUTS1-3
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Ege"@tr , "Aegean"@en ;
        skos:notation   "TR3" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-izmir , tr:prov-aydin , tr:prov-denizli ,
                        tr:prov-mugla , tr:prov-manisa , tr:prov-afyonkarahisar ,
                        tr:prov-kutahya , tr:prov-usak .

    tr:TR-NUTS1-4
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Doğu Marmara"@tr , "East Marmara"@en ;
        skos:notation   "TR4" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-bursa , tr:prov-eskisehir , tr:prov-bilecik ,
                        tr:prov-kocaeli , tr:prov-sakarya , tr:prov-duzce ,
                        tr:prov-bolu , tr:prov-yalova .

    tr:TR-NUTS1-5
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Batı Anadolu"@tr , "West Anatolia"@en ;
        skos:notation   "TR5" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-ankara , tr:prov-konya , tr:prov-karaman .

    tr:TR-NUTS1-6
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Akdeniz"@tr , "Mediterranean"@en ;
        skos:notation   "TR6" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-antalya , tr:prov-isparta , tr:prov-burdur ,
                        tr:prov-adana , tr:prov-mersin , tr:prov-hatay ,
                        tr:prov-kahramanmaras , tr:prov-osmaniye .

    tr:TR-NUTS1-7
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Orta Anadolu"@tr , "Central Anatolia"@en ;
        skos:notation   "TR7" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-kirikkale , tr:prov-aksaray , tr:prov-nigde ,
                        tr:prov-nevsehir , tr:prov-kirsehir , tr:prov-kayseri ,
                        tr:prov-sivas , tr:prov-yozgat .

    tr:TR-NUTS1-8
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Batı Karadeniz"@tr , "West Black Sea"@en ;
        skos:notation   "TR8" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-zonguldak , tr:prov-karabuk , tr:prov-bartin ,
                        tr:prov-kastamonu , tr:prov-cankiri , tr:prov-sinop ,
                        tr:prov-samsun , tr:prov-tokat , tr:prov-corum ,
                        tr:prov-amasya .

    tr:TR-NUTS1-9
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Doğu Karadeniz"@tr , "East Black Sea"@en ;
        skos:notation   "TR9" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-trabzon , tr:prov-ordu , tr:prov-giresun ,
                        tr:prov-rize , tr:prov-artvin , tr:prov-gumushane .

    tr:TR-NUTS1-10
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Kuzeydoğu Anadolu"@tr , "Northeast Anatolia"@en ;
        skos:notation   "TRA" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-erzurum , tr:prov-erzincan , tr:prov-bayburt ,
                        tr:prov-agri , tr:prov-kars , tr:prov-igdir ,
                        tr:prov-ardahan .

    tr:TR-NUTS1-11
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Ortadoğu Anadolu"@tr , "Central East Anatolia"@en ;
        skos:notation   "TRB" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-malatya , tr:prov-elazig , tr:prov-bingol ,
                        tr:prov-tunceli , tr:prov-van , tr:prov-mus ,
                        tr:prov-bitlis , tr:prov-hakkari .

    tr:TR-NUTS1-12
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "Güneydoğu Anadolu"@tr , "Southeast Anatolia"@en ;
        skos:notation   "TRC" ;
        skos:broader    tr:Turkey ;
        ngo:administrativeLevel level:Region ;
        skos:narrower   tr:prov-gaziantep , tr:prov-adiyaman , tr:prov-kilis ,
                        tr:prov-sanliurfa , tr:prov-diyarbakir , tr:prov-mardin ,
                        tr:prov-batman , tr:prov-siirt , tr:prov-sirnak .

    # ══════════════════════════════════════════════════════════════════════════
    #  İller  (81 il — temsili olarak tümü listelenmiştir)
    #  Her ilin kendi ilçeleri skos:narrower ile bağlanır.
    #  Detaylı ilçe listesi ayrı bir veri dosyasına taşınabilir.
    # ══════════════════════════════════════════════════════════════════════════

    # TR1 — İstanbul
    tr:prov-istanbul
        a skos:Concept ;
        skos:inScheme   tr:TurkeyAdminScheme ;
        skos:prefLabel  "İstanbul"@tr , "Istanbul"@en ;
        skos:notation   "TR-IST" ;
        skos:broader    tr:TR-NUTS1-1 ;
        ngo:administrativeLevel level:Province ;
        skos:exactMatch <http://www.wikidata.org/entity/Q406> ;
        skos:narrower
            tr:dist-kadikoy , tr:dist-besiktas , tr:dist-sisli ,
            tr:dist-fatih , tr:dist-beyoglu , tr:dist-uskudar ,
            tr:dist-maltepe , tr:dist-pendik , tr:dist-umraniye ,
            tr:dist-sariyer , tr:dist-bakirkoy , tr:dist-zeytinburnu ,
            tr:dist-bayrampasa , tr:dist-eyupsultan , tr:dist-gaziosmanpasa ,
            tr:dist-sultangazi , tr:dist-bagcilar , tr:dist-bahcelievler ,
            tr:dist-gungoren , tr:dist-kucukcekmece , tr:dist-avcilar ,
            tr:dist-buyukcekmece , tr:dist-esenyurt , tr:dist-basaksehir ,
            tr:dist-arnavutkoy , tr:dist-catalca , tr:dist-silivri ,
            tr:dist-cekmekoy , tr:dist-sultanbeyli , tr:dist-sancaktepe ,
            tr:dist-tuzla , tr:dist-kartal , tr:dist-adalar ,
            tr:dist-beykoz , tr:dist-sile , tr:dist-catalca .

    # TR2 — Batı Marmara
    tr:prov-tekirdag    a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Tekirdağ"@tr , "Tekirdağ"@en ; skos:notation "TR-TEK" ;
        skos:broader tr:TR-NUTS1-2 ; ngo:administrativeLevel level:Province ;
        skos:exactMatch <http://www.wikidata.org/entity/Q131654> .
    tr:prov-edirne      a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Edirne"@tr , "Edirne"@en ; skos:notation "TR-EDI" ;
        skos:broader tr:TR-NUTS1-2 ; ngo:administrativeLevel level:Province ;
        skos:exactMatch <http://www.wikidata.org/entity/Q131681> .
    tr:prov-kirklareli  a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Kırklareli"@tr , "Kırklareli"@en ; skos:notation "TR-KLR" ;
        skos:broader tr:TR-NUTS1-2 ; ngo:administrativeLevel level:Province .
    tr:prov-balikesir   a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Balıkesir"@tr , "Balıkesir"@en ; skos:notation "TR-BAL" ;
        skos:broader tr:TR-NUTS1-2 ; ngo:administrativeLevel level:Province .
    tr:prov-canakkale   a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Çanakkale"@tr , "Çanakkale"@en ; skos:notation "TR-CAN" ;
        skos:broader tr:TR-NUTS1-2 ; ngo:administrativeLevel level:Province .

    # TR3 — Ege
    tr:prov-izmir       a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "İzmir"@tr , "İzmir"@en ; skos:notation "TR-IZM" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province ;
        skos:exactMatch <http://www.wikidata.org/entity/Q79867> .
    tr:prov-aydin       a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Aydın"@tr , "Aydın"@en ; skos:notation "TR-AYD" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-denizli     a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Denizli"@tr , "Denizli"@en ; skos:notation "TR-DNZ" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-mugla       a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Muğla"@tr , "Muğla"@en ; skos:notation "TR-MUG" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-manisa      a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Manisa"@tr , "Manisa"@en ; skos:notation "TR-MAN" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-afyonkarahisar a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Afyonkarahisar"@tr , "Afyonkarahisar"@en ; skos:notation "TR-AFY" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-kutahya     a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Kütahya"@tr , "Kütahya"@en ; skos:notation "TR-KUT" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .
    tr:prov-usak        a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Uşak"@tr , "Uşak"@en ; skos:notation "TR-USK" ;
        skos:broader tr:TR-NUTS1-3 ; ngo:administrativeLevel level:Province .

    # TR4 — Doğu Marmara
    tr:prov-bursa       a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Bursa"@tr , "Bursa"@en ; skos:notation "TR-BUR" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province ;
        skos:exactMatch <http://www.wikidata.org/entity/Q41339> .
    tr:prov-eskisehir   a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Eskişehir"@tr , "Eskişehir"@en ; skos:notation "TR-ESK" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-bilecik     a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Bilecik"@tr , "Bilecik"@en ; skos:notation "TR-BLC" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-kocaeli     a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Kocaeli"@tr , "Kocaeli"@en ; skos:notation "TR-KOC" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-sakarya     a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Sakarya"@tr , "Sakarya"@en ; skos:notation "TR-SAK" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-duzce       a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Düzce"@tr , "Düzce"@en ; skos:notation "TR-DUZ" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-bolu        a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Bolu"@tr , "Bolu"@en ; skos:notation "TR-BOL" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .
    tr:prov-yalova      a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
        skos:prefLabel "Yalova"@tr , "Yalova"@en ; skos:notation "TR-YAL" ;
        skos:broader tr:TR-NUTS1-4 ; ngo:administrativeLevel level:Province .

    # TR5 — Batı Anadolu
    tr:prov-ankara      a skos:Concept ; skos:inScheme tr:TurkeyAdminScheme ;
