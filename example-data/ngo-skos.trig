        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:topConceptOf ngos:TopicScheme ;
        skos:prefLabel "Kadın İşleri"@tr , "Women's Affairs"@en ;
        skos:notation  "T-WOM" .

    topic:DisabilityInclusion
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:topConceptOf ngos:TopicScheme ;
        skos:prefLabel "Engelli Katılımı"@tr , "Disability Inclusion"@en ;
        skos:notation  "T-DIS" .
}

###############################################################################
#  GRAPH S4 — Membership Lifecycle Scheme  (üyelik yaşam döngüsü açıklamaları)
#  Bu şema ngo:MembershipStatus enum bireylerini SKOS yapısına entegre eder.
###############################################################################

ngog:skos-membership-lifecycle {

    ngos:MembershipLifecycleScheme
        a skos:ConceptScheme ;
        skos:prefLabel  "Üyelik Yaşam Döngüsü"@tr ,
                        "Membership Lifecycle"@en ;
        skos:definition "Bir kişinin NGO'ya ilk başvurusundan tam resmi üyeliğe uzanan statü aşamalarını SKOS ile belgeler."@tr ,
                        "Documents via SKOS the membership status stages from first application to full formal membership."@en ;
        skos:hasTopConcept ngos:MLC-Start .

    ngos:MLC-Start
        a skos:Concept ;
        skos:inScheme ngos:MembershipLifecycleScheme ;
        skos:topConceptOf ngos:MembershipLifecycleScheme ;
        skos:prefLabel  "Başvuru Aşaması"@tr , "Application Stage"@en ;
        skos:scopeNote  "Kişi merkeze başvurdu; henüz hiçbir birim oluşmamış."@tr ,
                        "Person applied to HQ; no territorial unit exists yet."@en ;
        skos:closeMatch ngo:Applicant ;
        skos:narrower   ngos:MLC-Transfer .

    ngos:MLC-Transfer
        a skos:Concept ;
        skos:inScheme ngos:MembershipLifecycleScheme ;
        skos:prefLabel  "Temsilciliğe Aktarım"@tr , "Transfer to Representation"@en ;
        skos:scopeNote  "İl temsilciliği kurulunca merkez başvurucuları bu birime aktarılır. Statü: InformalMember veya VolunteerMember."@tr ,
                        "When a provincial representation is established, HQ applicants are transferred. Status: InformalMember or VolunteerMember."@en ;
        skos:broader    ngos:MLC-Start ;
        skos:narrower   ngos:MLC-Candidate .

    ngos:MLC-Candidate
        a skos:Concept ;
        skos:inScheme ngos:MembershipLifecycleScheme ;
        skos:prefLabel  "Aday Üye Aşaması"@tr , "Candidate Stage"@en ;
        skos:scopeNote  "Aktif katılımı yüksek InformalMember'lar CandidateMember statüsüne geçer; davranışları belirsiz süre izlenir."@tr ,
                        "InformalMembers with high participation move to CandidateMember; observed for an indefinite period."@en ;
        skos:closeMatch ngo:CandidateMember ;
        skos:broader    ngos:MLC-Transfer ;
        skos:narrower   ngos:MLC-Formal .

    ngos:MLC-Formal
        a skos:Concept ;
        skos:inScheme ngos:MembershipLifecycleScheme ;
        skos:prefLabel  "Resmi Üyelik"@tr , "Formal Membership"@en ;
        skos:scopeNote  "İlçe başkanlığı kurulunca, aidat yatıran CandidateMember'lar FormalMember olur. Tek ilçeye bağlı."@tr ,
                        "Once a district presidency is established, fee-paying candidates become FormalMembers. Bound to exactly one district."@en ;
        skos:closeMatch ngo:FormalMember ;
        skos:broader    ngos:MLC-Candidate .

    ngos:MLC-Volunteer
        a skos:Concept ;
        skos:inScheme ngos:MembershipLifecycleScheme ;
        skos:prefLabel  "Gönüllü Üyelik (Paralel Yol)"@tr , "Volunteer Membership (Parallel Path)"@en ;
        skos:scopeNote  "Aktif katılım istemeyenler InformalMember'dan bu statüye geçer; bu bir son nokta statüsüdür."@tr ,
                        "Those not wishing active participation move from InformalMember to this status; it is a terminal status."@en ;
        skos:closeMatch ngo:VolunteerMember ;
        skos:broader    ngos:MLC-Transfer .
}
