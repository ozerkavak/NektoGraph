###############################################################################
#  GRAPH S3 — Topic Scheme  (NGO konu sınıflandırması)
###############################################################################

ngog:skos-topics {

    ngos:TopicScheme
        a skos:ConceptScheme ;
        skos:prefLabel  "NGO Konu Sınıflandırması"@tr ,
                        "NGO Topic Classification"@en ;
        skos:definition "Komisyon, proje, iş kalemi ve üye ilgi alanlarını kategorize eden ana konu şeması."@tr ,
                        "Master subject scheme categorising commissions, projects, work items and member interest areas."@en ;
        dct:created     "2025-04-24"^^xsd:date ;
        skos:hasTopConcept
            topic:Environment ,
            topic:SocialAffairs ,
            topic:Economy ,
            topic:Education ,
            topic:Health ,
            topic:Culture ,
            topic:Law ,
            topic:Technology ,
            topic:Agriculture ,
            topic:HumanRights ,
            topic:LocalGovernance ,
            topic:InternationalRelations ,
            topic:CommunicationMedia ,
            topic:YouthSports ,
            topic:WomenAffairs ,
            topic:DisabilityInclusion .

    # ── Ana Konular ───────────────────────────────────────────────────────────

    topic:Environment
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:topConceptOf ngos:TopicScheme ;
        skos:prefLabel  "Çevre ve Sürdürülebilirlik"@tr , "Environment & Sustainability"@en ;
        skos:notation   "T-ENV" ;
        skos:narrower   topic:ClimateChange , topic:Biodiversity ,
                        topic:WasteManagement , topic:WaterResources ,
                        topic:RenewableEnergy .

    topic:ClimateChange
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "İklim Değişikliği"@tr , "Climate Change"@en ;
        skos:broader   topic:Environment ; skos:notation "T-ENV-CC" .

    topic:Biodiversity
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Biyoçeşitlilik"@tr , "Biodiversity"@en ;
        skos:broader   topic:Environment ; skos:notation "T-ENV-BD" .

    topic:WasteManagement
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Atık Yönetimi"@tr , "Waste Management"@en ;
        skos:broader   topic:Environment ; skos:notation "T-ENV-WM" .

    topic:WaterResources
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Su Kaynakları"@tr , "Water Resources"@en ;
        skos:broader   topic:Environment ; skos:notation "T-ENV-WR" .

    topic:RenewableEnergy
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Yenilenebilir Enerji"@tr , "Renewable Energy"@en ;
        skos:broader   topic:Environment ; skos:notation "T-ENV-RE" .

    topic:SocialAffairs
        a skos:Concept , ngo:Topic ;
        skos:inScheme ngos:TopicScheme ;
        skos:topConceptOf ngos:TopicScheme ;
        skos:prefLabel  "Sosyal İşler"@tr , "Social Affairs"@en ;
        skos:notation   "T-SOC" ;
        skos:narrower   topic:Poverty , topic:Housing ,
                        topic:MigrantRefugee , topic:ElderlyAffairs ,
                        topic:ChildProtection .

    topic:Poverty         a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Yoksulluk"@tr , "Poverty"@en ; skos:broader topic:SocialAffairs ; skos:notation "T-SOC-POV" .
    topic:Housing         a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Konut"@tr , "Housing"@en ; skos:broader topic:SocialAffairs ; skos:notation "T-SOC-HOU" .
    topic:MigrantRefugee  a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Göç ve Mülteci"@tr , "Migration & Refugee"@en ; skos:broader topic:SocialAffairs ; skos:notation "T-SOC-MIG" .
    topic:ElderlyAffairs  a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Yaşlı İşleri"@tr , "Elderly Affairs"@en ; skos:broader topic:SocialAffairs ; skos:notation "T-SOC-ELD" .
    topic:ChildProtection a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Çocuk Koruma"@tr , "Child Protection"@en ; skos:broader topic:SocialAffairs ; skos:notation "T-SOC-CHD" .

    topic:Economy
