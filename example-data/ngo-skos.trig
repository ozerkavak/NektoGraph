    topic:Finance      a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
        skos:prefLabel "Finans ve Bankacılık"@tr , "Finance & Banking"@en ; skos:broader topic:Economy ; skos:notation "T-ECO-FIN" .
    topic:Employment   a skos:Concept , ngo:Topic ; skos:inScheme ngos:TopicScheme ;
