@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <http://www.40nodes.net/ontologies/ngo#> .

<http://www.40nodes.net/ontologies/ngo/data/skos-data> {

    # --- KONSEPT ŞEMALARI ---
    :id_SKOS_SCH1 a skos:ConceptScheme ; rdfs:label "Membership Levels"@en, "Üyelik Seviyeleri"@tr .
    :id_SKOS_SCH2 a skos:ConceptScheme ; rdfs:label "End Reasons"@en, "Bitiş Nedenleri"@tr .

    # --- ÜYELİK SEVİYELERİ ---
    :id_SKOS_LVL1 a skos:Concept ; skos:inScheme :id_SKOS_SCH1 ; skos:topConceptOf :id_SKOS_SCH1 ;
        rdfs:label "Official Member"@en, "Resmi Üye"@tr ; owl:differentFrom :id_SKOS_LVL2 .
    :id_SKOS_LVL2 a skos:Concept ; skos:inScheme :id_SKOS_SCH1 ; skos:topConceptOf :id_SKOS_SCH1 ;
        rdfs:label "Unofficial Member"@en, "Gayrı-Resmi Üye"@tr .

    # --- BİTİŞ NEDENLERİ (Ana Kategoriler) - U1 Düzeltmesi ---
    :id_SKOS_END1 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:topConceptOf :id_SKOS_SCH2 ; rdfs:label "Neutral End"@en, "Nötr Bitiş"@tr .
    :id_SKOS_END2 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:topConceptOf :id_SKOS_SCH2 ; rdfs:label "Voluntary End"@en, "Gönüllü Bitiş"@tr .
    :id_SKOS_END3 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:topConceptOf :id_SKOS_SCH2 ; rdfs:label "Sanction End"@en, "Yaptırım/Cezai Bitiş"@tr .

    # --- BİTİŞ NEDENLERİ (Alt Kategoriler) - inScheme Eksikliği Giderildi ---
    :id_SKOS_END4 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Membership Type Change"@en, "Üyelik Tipi Değişikliği"@tr .
    :id_SKOS_END5 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Structural Upgrade"@en, "Birim Statü Yükselmesi"@tr .
    :id_SKOS_END6 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Mandatory Leave"@en, "Zorunlu Ayrılış"@tr .
    :id_SKOS_END7 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Death"@en, "Vefat"@tr .
    :id_SKOS_END8 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Dissolution/Merger"@en, "Fesih/Birleşme"@tr .
    :id_SKOS_END9 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END1 ; rdfs:label "Transformation to Official Status"@en, "Resmi Statüye Dönüşüm"@tr .
    :id_SKOS_END10 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END2 ; rdfs:label "Resignation"@en, "İstifa"@tr .
    :id_SKOS_END11 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END3 ; rdfs:label "Temporary Expulsion"@en, "Geçici İhraç"@tr .
    :id_SKOS_END12 a skos:Concept ; skos:inScheme :id_SKOS_SCH2 ; skos:broader :id_SKOS_END3 ; rdfs:label "Permanent Expulsion"@en, "Kalıcı İhraç"@tr .
}