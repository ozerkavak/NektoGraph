###############################################################################
#  NGO CORE ONTOLOGY — Kurumsal Hiyerarşi Modülü
#  Dosya    : NGO-ontology.trig
#  Format   : TriG (RDF 1.2 / RDF-Star)
#  Versiyon : 0.3.1
#  Demand   : DEMAND-NGO-001
#  Lisans   : CC BY 4.0
###############################################################################

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix ngo:   <http://40nodes.net/ngo#> .
@prefix ngo40: <http://40nodes.net/ngo/> .


GRAPH <http://40nodes.net/ngo/ontology> {

###############################################################################
#  GRAPH 1 — Ontoloji Metadata
###############################################################################

    <http://40nodes.net/ngo/ontology>
        a owl:Ontology ;
        rdfs:label
            "NGO Çekirdek Ontolojisi — Kurumsal Hiyerarşi + Kişi Modeli"@tr ,
            "NGO Core Ontology — Organisational Hierarchy + Person Model"@en ;
        rdfs:comment
            "STK / siyasi parti yapılarının kurumsal hiyerarşisini, birim türlerini, coğrafi teşkilatlanmayı, koordinasyon katmanlarını ve kişi/üyelik modelini tanımlayan OWL 2 RL ontolojisi. Instance URI'leri ngo40: (<http://40nodes.net/ngo/>) prefix ile d+8char (data) veya v+8char (vocabulary) formatındadır. Sınıf ve property URI'leri ngo: (<http://40nodes.net/ngo#>) prefix'indedir."@tr ,
            "OWL 2 RL ontology modelling the organisational hierarchy of NGOs and political parties, including unit types, territorial organisation, coordination layers, and the person/membership model. Instance IRIs use the ngo40: (<http://40nodes.net/ngo/>) prefix in d+8char (data) or v+8char (vocabulary) format. Class and property IRIs are in the ngo: (<http://40nodes.net/ngo#>) namespace."@en ;
        owl:versionIRI    <http://40nodes.net/ngo/ontology/0.3.1> ;
        owl:versionInfo   "0.3.1" ;
        dct:created       "2026-04-27"^^xsd:date ;
        dct:modified      "2026-04-29"^^xsd:date ;
        dct:language      "tr" , "en" ;
        dct:license       <https://creativecommons.org/licenses/by/4.0/> ;
        rdfs:seeAlso
            <http://www.w3.org/ns/org#> ,
            <http://www.w3.org/ns/prov#> ,
            <http://www.w3.org/2004/02/skos/core#> .


###############################################################################
#  GRAPH 2 — Annotation Properties
#  RDF-Star triple annotation için kullanılan bağlam özellikleri.
#  Değerleri reifier node'ları veya annotation sözdizimi üzerinde taşınır.
###############################################################################

    # ── Temporal ──────────────────────────────────────────────────────────────

    ngo:startDate
        a owl:AnnotationProperty ;
        rdfs:label   "Başlangıç Tarihi"@tr , "Start Date"@en ;
        rdfs:comment
            "Reify edilmiş veya annotate edilmiş triple'ın geçerlilik başlangıcı. Bu tarih dahildir. Birim kuruluş tarihinden farklıdır; triple'ın (örn. hiyerarşik bağ veya tip) ne zaman geçerli olmaya başladığını belirtir.\nÖrnek: _:r1 rdf:reifies <<( ngo:KadikoyBirimi ngo:subUnitOf ngo:IstanbulIlBaskanligi )>> ; ngo:startDate \"2024-01-15\"^^xsd:date ."@tr ,
            "Validity start of a reified or annotated triple. This date is inclusive. Distinct from unit founding date; indicates when the triple (e.g. a hierarchical link or type assertion) became valid.\nExample: _:r1 rdf:reifies <<( ngo:KadikoyBirimi ngo:subUnitOf ngo:IstanbulIlBaskanligi )>> ; ngo:startDate \"2024-01-15\"^^xsd:date ."@en ;
        rdfs:range   xsd:date .

    ngo:endDate
        a owl:AnnotationProperty ;
        rdfs:label   "Bitiş Tarihi"@tr , "End Date"@en ;
        rdfs:comment
            "Reify edilmiş triple'ın geçerlilik sonu. Bu tarih dahildir. Yoksa triple hâlâ aktif demektir. Temsilciliğin başkanlığa dönüşümünde eski reifier node'una endDate eklenir.\nÖrnek: _:r1 ngo:endDate \"2023-12-31\"^^xsd:date ."@tr ,
            "Validity end of a reified triple. This date is inclusive. Absent means currently active. When a representation converts to a presidency, the old reifier node receives an endDate.\nExample: _:r1 ngo:endDate \"2023-12-31\"^^xsd:date ."@en ;
        rdfs:range   xsd:date .

    # ── Birim Bağlamı ──────────────────────────────────────────────────────────

    ngo:isLegalEntity
        a owl:DatatypeProperty , owl:FunctionalProperty ;
        rdfs:label   "Tüzel Kişilik"@tr , "Legal Entity"@en ;
        rdfs:domain  ngo:TerritorialUnit ;
        rdfs:range   xsd:boolean ;
        rdfs:comment
            "Birimin tüzel kişiliğe sahip olup olmadığını belirtir. Temsilcilikler false, Başkanlıklar true değerini taşır. Temsilcilik kapanıp yeni Başkanlık kurulduğunda ayrı IRI'lar kullanılır.\nÖrnek: ngo40:dXXX ngo:isLegalEntity true . # Başkanlık"@tr ,
            "Whether the unit holds legal personality. Representations carry false, Presidencies carry true. When a Representation closes and a new Presidency is established, separate IRIs are used.\nExample: ngo40:dXXX ngo:isLegalEntity true . # Presidency"@en .

    ngo:legalBasis
        a owl:AnnotationProperty ;
        rdfs:label   "Yasal Dayanak"@tr , "Legal Basis"@en ;
        rdfs:comment
            "Triple'ın dayandığı kanun maddesi, tüzük hükmü veya resmi kararın metinsel referansı.\nÖrnek: ngo40:dXXX ngo:legalBasis \"Tüzük Md. 14 — İl Başkanlığı Kuruluşu\" ."@tr ,
            "Textual reference to the statute article, bylaw clause, or formal decision underpinning the triple.\nExample: ngo40:dXXX ngo:legalBasis \"Bylaw Art. 14 — Establishment of Provincial Presidency\" ."@en ;
        rdfs:range   xsd:string .

    ngo:endReason
        a owl:AnnotationProperty ;
        rdfs:label   "Bitiş Nedeni"@tr , "End Reason"@en ;
        rdfs:comment
            "Reify edilmiş triple'ın sona erme nedeni. Değer ngo:EndReasonScheme'den bir ngo:Concept'tir. endDate ile birlikte kullanılır; endDate yoksa bu property anlamsızdır.\nÖrnek: _:r1 ngo:endDate \"2025-03-01\"^^xsd:date ; ngo:endReason ngo40:ver2dth8 . # Death"@tr ,
            "Reason why a reified triple ended. Value is an ngo:Concept from ngo:EndReasonScheme. Used alongside endDate; meaningless without it.\nExample: _:r1 ngo:endDate \"2025-03-01\"^^xsd:date ; ngo:endReason ngo40:ver2dth8 . # Death"@en ;
        rdfs:range   ngo:EndReasonConcept .

    ngo:officerRole
        a owl:AnnotationProperty ;
        rdfs:label   "Görev Rolü"@tr , "Officer Role"@en ;
        rdfs:range   ngo:OfficerRoleConcept ;
        rdfs:comment
            "ngo:hasOfficer triple'ını annotate ederek kişinin birimde üstlendiği rolü belirtir. Değer ngo:OfficerRoleScheme'den bir ngo:OfficerRoleConcept'tir. Basit durumda {||} kısa sözdizimi; aynı (birim, kişi) çifti için birden fazla rol veya dönem söz konusuysa rdf:reifies explicit formu kullanılır.\nÖrnek: ngo40:dBSK ngo:hasOfficer ngo40:dpXXX {| ngo:officerRole ngo40:vorf4ilb ; ngo:startDate \"2024-01-01\"^^xsd:date |} ."@tr ,
            "Annotates the ngo:hasOfficer triple to specify the role held by the person in the unit. Value is an ngo:OfficerRoleConcept from ngo:OfficerRoleScheme. Use {||} shorthand for simple cases; use explicit rdf:reifies when the same (unit, person) pair has multiple roles or terms.\nExample: ngo40:dBSK ngo:hasOfficer ngo40:dpXXX {| ngo:officerRole ngo40:vorf4ilb ; ngo:startDate \"2024-01-01\"^^xsd:date |} ."@en .


###############################################################################
#  GRAPH 3 — Sınıflar (11 adet)
###############################################################################

    # ══════════════════════════════════════════════════════════════════════════
    #  A. NGOUnit — Soyut Üst Sınıf
    # ══════════════════════════════════════════════════════════════════════════

    ngo:NGOUnit
        a owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/org#Organization> , <http://www.w3.org/ns/prov#Agent> ;
        rdfs:label   "NGO Birimi"@tr , "NGO Unit"@en ;
        rdfs:comment
            "NGO'nun herhangi bir düzeydeki birimi için soyut üst sınıf. Doğrudan kullanılmaz; Headquarter, HQDepartment, TerritorialUnit gibi alt sınıflar kullanılır. W3C ORG ontolojisinin org:Organization sınıfından türetilmiştir; aynı zamanda PROV-O'da prov:Agent olarak da tanınır (aktivitelerde sorumlu birim olarak kullanılabilmesi için).\nÖrnek (dolaylı): ngo40:dXXX a ngo:TerritorialUnit . (NGOUnit'in dolaylı örneği)"@tr ,
            "Abstract superclass for any unit of the NGO at any level. Not used directly; subclasses such as Headquarter, HQDepartment, TerritorialUnit are used instead. Derived from W3C ORG's org:Organization; also typed as prov:Agent so units can act as responsible parties in PROV-O activities.\nExample (indirect): ngo40:dXXX a ngo:TerritorialUnit . (indirect instance of NGOUnit)"@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  B. Genel Merkez — ngo:NGOUnit ile temsil edilir
    # ══════════════════════════════════════════════════════════════════════════

    # ══════════════════════════════════════════════════════════════════════════
    #  D. Kurullar / Meclisler
    # ══════════════════════════════════════════════════════════════════════════

    ngo:GoverningBody
        a owl:Class ;
        rdfs:subClassOf ngo:NGOUnit ;
        rdfs:label   "Kurul / Meclis"@tr , "Governing Body"@en ;
        rdfs:comment
            "Herhangi bir düzeydeki resmi karar alma organı. Merkez düzeyindeki kurullar (MYK, Parti Meclisi, Merkez Disiplin Kurulu, Kurucular Kurulu) ve yerel düzeydeki kurullar (Yerel Meclis, Yerel Disiplin Kurulu) bu sınıfın örnekleridir. Kurul tipi ngo:Concept ile ayrışır. Bir birime ngo:hasGoverningBody ile bağlanır.\nÖrnek: ngo:MerkezYurutmeKurulu a ngo:GoverningBody ; rdfs:label \"Merkez Yürütme Kurulu\"@tr ; ngo:hasGoverningBody ngo:GenelMerkez ."@tr ,
            "Formal decision-making body at any level. Central-level bodies (CEB, Party Council, Central Disciplinary Board, Founders Council) and local bodies (Local Assembly, Local Disciplinary Board) are instances of this class. Board type is distinguished via ngo:Concept. Linked to its parent unit via ngo:hasGoverningBody.\nExample: ngo:MerkezYurutmeKurulu a ngo:GoverningBody ; rdfs:label \"Central Executive Board\"@en ; ngo:hasGoverningBody ngo:GenelMerkez ."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  E. Koordinasyon Katmanı
    # ══════════════════════════════════════════════════════════════════════════

    ngo:CoordinationZone
        a owl:Class ;
        rdfs:subClassOf ngo:NGOUnit ;
        rdfs:label   "Koordinasyon Bölgesi"@tr , "Coordination Zone"@en ;
        rdfs:comment
            "Resmi tüzel kişiliği bulunmayan, yalnızca bir sorumlu kişiye sahip coğrafi koordinasyon katmanı. Türkiye için 7 bölge teşkilatı ve 1 yurtdışı teşkilatı bu sınıfın örnekleridir. Başkanlığa dönüşmez; alt bölgelere bölünebilir (Doğu Marmara, Batı Marmara). Sorumlu kişi aynı zamanda başka bir birimin başkanı veya temsilcisi olabilir. Alt bölgeler ngo:subUnitOf ile birbirine bağlanır.\nÖrnek: ngo:MarmaraBolgesi a ngo:CoordinationZone ; ngo:subUnitOf ngo:TeşkilatlanmaBaskanligi ; ngo:covers ngo:IstanbulIlBaskanligi , ngo:BursaIlBaskanligi ."@tr ,
            "Geographic coordination layer with no legal personality, represented by a single responsible person. Instances include the 7 regional organisations and the overseas organisation. Does not convert to a presidency; can be split into sub-zones (East Marmara, West Marmara). The responsible person may simultaneously lead another unit. Sub-zones are linked via ngo:subUnitOf.\nExample: ngo:MarmaraBolgesi a ngo:CoordinationZone ; ngo:subUnitOf ngo:TeşkilatlanmaBaskanligi ; ngo:covers ngo:IstanbulIlBaskanligi , ngo:BursaIlBaskanligi ."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  F. Coğrafi Teşkilat Birimleri (Soyut Üst)
    # ══════════════════════════════════════════════════════════════════════════

    ngo:TerritorialUnit
        a owl:Class ;
        rdfs:subClassOf ngo:NGOUnit ;
        rdfs:label   "Coğrafi Teşkilat Birimi"@tr , "Territorial Unit"@en ;
        rdfs:comment
            "Belirli bir idari coğrafyaya (il, ilçe, mahalle/köy, ülke vb.) karşılık gelen teşkilat biriminin soyut üst sınıfı. Tüm coğrafi birimler doğrudan bu sınıftan örneklenir. Tüzel kişilik durumu ngo:isLegalEntity ile, aktiflik durumu ngo:dissolutionDate varlığı/yokluğu ile belirlenir. İdari kademe ngo:administrativeLevel ile, kapsanan alan ngo:administrativeArea ile ngo:Concept olarak belirtilir.\nÖrnek: ngo40:dXXX a ngo:TerritorialUnit ; ngo:isLegalEntity true ; ngo:administrativeLevel ngo40:vpl3m7kx .  # ProvinceLevel Başkanlık"@tr ,
            "Abstract superclass for a territorial organisation unit corresponding to an administrative geography (province, district, neighbourhood/village, country, etc.). All territorial units are instantiated directly from this class. Legal personality is indicated by ngo:isLegalEntity; active/dissolved status by presence or absence of ngo:dissolutionDate. Administrative level is indicated via ngo:administrativeLevel and geographic area via ngo:administrativeArea, both as ngo:Concept values.\nExample: ngo40:dXXX a ngo:TerritorialUnit ; ngo:isLegalEntity true ; ngo:administrativeLevel ngo40:vpl3m7kx . # ProvinceLevel Presidency"@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  G. Görev Birimleri (Komisyon / Çalışma Grubu)
    # ══════════════════════════════════════════════════════════════════════════

    ngo:TaskUnit
        a owl:Class ;
        rdfs:subClassOf ngo:NGOUnit ;
        rdfs:label   "Görev Birimi"@tr , "Task Unit"@en ;
        rdfs:comment
            "Belirli bir amaç veya konuya yönelik oluşturulan komisyon veya çalışma grubu için soyut üst sınıf. Doğrudan kullanılmaz; Commission veya WorkingGroup olarak örneklenir. Herhangi bir NGO birimi düzeyinde kurulabilir. Kalıcı mı geçici mi olduğu ngo:isPermanent ile belirtilir.\nÖrnek (dolaylı): ngo:MerkezEkonomiKomisyonu a ngo:Commission ."@tr ,
            "Abstract superclass for commissions or working groups formed for a specific purpose or topic. Not used directly; instantiated as Commission or WorkingGroup. Can be established at any NGO unit level. Whether permanent or temporary is indicated via ngo:isPermanent.\nExample (indirect): ngo:MerkezEkonomiKomisyonu a ngo:Commission ."@en .

    ngo:Commission
        a owl:Class ;
        rdfs:subClassOf ngo:TaskUnit ;
        rdfs:label   "Komisyon"@tr , "Commission"@en ;
        rdfs:comment
            "Tüzükte veya resmi kararla oluşturulan, belirli bir konuda faaliyet yürüten komisyon. Kalıcı (ngo:isPermanent true) veya geçici olabilir. Merkez ekonomi komisyonu, X ilçesi tarım komisyonu gibi örnekler bu sınıfa aittir. Bir üst birime ngo:subUnitOf ile bağlanır.\nÖrnek: ngo:MerkezEkonomiKomisyonu a ngo:Commission ; ngo:isPermanent true ; ngo:subUnitOf ngo:GenelMerkez . ngo:GenelMerkez ngo:hasTaskUnit ngo:MerkezEkonomiKomisyonu ."@tr ,
            "Commission formed by statute or formal decision to operate in a specific area. May be permanent (ngo:isPermanent true) or temporary. Central economy commission, district agriculture commission are examples of this class. Linked to its parent unit via ngo:subUnitOf.\nExample: ngo:MerkezEkonomiKomisyonu a ngo:Commission ; ngo:isPermanent true ; ngo:subUnitOf ngo:GenelMerkez . ngo:GenelMerkez ngo:hasTaskUnit ngo:MerkezEkonomiKomisyonu ."@en .

    ngo:WorkingGroup
        a owl:Class ;
        rdfs:subClassOf ngo:TaskUnit ;
        rdfs:label   "Çalışma Grubu"@tr , "Working Group"@en ;
        rdfs:comment
            "Belirli bir çalışma veya projeyi yürütmek için oluşturulan, genellikle geçici, daha az resmi yapı. Komisyona göre daha esnek ve kısa ömürlüdür. Herhangi bir NGO birimi düzeyinde kurulabilir.\nÖrnek: ngo:AnayasaCalismGrubu a ngo:WorkingGroup ; ngo:isPermanent false ; ngo:subUnitOf ngo:HukukIşleriBaskanligi ."@tr ,
            "Less formal, usually temporary group formed to carry out a specific task or project. More flexible and shorter-lived than a commission. Can be established at any NGO unit level.\nExample: ngo:AnayasaCalismGrubu a ngo:WorkingGroup ; ngo:isPermanent false ; ngo:subUnitOf ngo:HukukIşleriBaskanligi ."@en .


###############################################################################
#  GRAPH 4 — Object Properties (10 adet)
###############################################################################

    # ══════════════════════════════════════════════════════════════════════════
    #  A. Hiyerarşi
    # ══════════════════════════════════════════════════════════════════════════

    ngo:subUnitOf
        a owl:ObjectProperty ;
        rdfs:subPropertyOf ngo:transitiveSubUnitOf ;
        rdfs:seeAlso       <http://www.w3.org/ns/org#subOrganizationOf> ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "alt birimi olduğu"@tr , "sub-unit of"@en ;
        rdfs:comment
            "Bir birimin doğrudan üst birimine olan hiyerarşik bağı. Transitif değildir; yalnızca doğrudan ebeveyn birimi ifade eder. Transitif kapanım için ngo:transitiveSubUnitOf kullanın. Tüm NGO birim türleri bu property'yi kullanabilir: TerritorialUnit, CoordinationZone, HQDepartment, TaskUnit vb.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:subUnitOf ngo:IstanbulIlBaskanligi .\nngo:MarmaraBolgesi ngo:subUnitOf ngo:TeşkilatlanmaBaskanligi ."@tr ,
            "Direct hierarchical link of a unit to its immediate parent. Non-transitive; expresses only the direct parent. Use ngo:transitiveSubUnitOf for transitive closure. All NGO unit types may use this property: TerritorialUnit, CoordinationZone, HQDepartment, TaskUnit, etc.\nExample: ngo:KadikoyIlceBaskanligi ngo:subUnitOf ngo:IstanbulIlBaskanligi .\nngo:MarmaraBolgesi ngo:subUnitOf ngo:TeşkilatlanmaBaskanligi ."@en .

    ngo:hasSubUnit
        a owl:ObjectProperty ;
        owl:inverseOf ngo:subUnitOf ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "alt birimi"@tr , "has sub-unit"@en ;
        rdfs:comment
            "ngo:subUnitOf'un tersi. Bir üst birimin doğrudan alt birimlerini verir. Reasoner tarafından otomatik çıkarılır; veriye elle eklenmesi gerekmez, ancak sorgu kolaylığı için eklenebilir.\nÖrnek: ngo:IstanbulIlBaskanligi ngo:hasSubUnit ngo:KadikoyIlceBaskanligi ."@tr ,
            "Inverse of ngo:subUnitOf. Returns the direct sub-units of a parent unit. Inferred automatically by a reasoner; need not be asserted in data, but may be added for query convenience.\nExample: ngo:IstanbulIlBaskanligi ngo:hasSubUnit ngo:KadikoyIlceBaskanligi ."@en .

    ngo:transitiveSubUnitOf
        a owl:ObjectProperty , owl:TransitiveProperty ;
        rdfs:seeAlso       <http://www.w3.org/ns/org#transitiveSubOrganizationOf> ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "transitif alt birimi olduğu"@tr , "transitive sub-unit of"@en ;
        rdfs:comment
            "ngo:subUnitOf'un transitif kapanımı. Bir birimin tüm üst birimlerini (doğrudan ve dolaylı) bulmak için kullanılır. owl:propertyChainAxiom ile tanımlanmıştır: (ngo:subUnitOf ∘ ngo:transitiveSubUnitOf). Döngü içermemelidir; bkz. IC-02.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:transitiveSubUnitOf ngo:IstanbulIlBaskanligi . (doğrudan)\nngo:KadikoyIlceBaskanligi ngo:transitiveSubUnitOf ngo:GenelMerkez . (reasoner çıkarımı)"@tr ,
            "Transitive closure of ngo:subUnitOf. Used to find all ancestor units (direct and indirect) of a given unit. Defined via owl:propertyChainAxiom: (ngo:subUnitOf ∘ ngo:transitiveSubUnitOf). Must not contain cycles; see IC-02.\nExample: ngo:KadikoyIlceBaskanligi ngo:transitiveSubUnitOf ngo:IstanbulIlBaskanligi . (direct)\nngo:KadikoyIlceBaskanligi ngo:transitiveSubUnitOf ngo:GenelMerkez . (reasoner inference)"@en .

    ngo:reportsTo
        a owl:ObjectProperty ;
        rdfs:seeAlso       <http://www.w3.org/ns/org#reportsTo> ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "raporladığı birim"@tr , "reports to"@en ;
        rdfs:comment
            "Birimin raporlama sorumluluğu taşıdığı üst birim. Hiyerarşik bağdan (ngo:subUnitOf) farklı olabilir. Yerel sekreterler informal olarak Genel Sekreterliğe, yerel saymanlar Genel Saymanlığa raporlar. Bu property hem formal hem informal raporlama bağlarını taşıyabilir; bağlamı RDF-Star annotation ile belirtilebilir.\nÖrnek: ngo:KadikoySekreteri ngo:reportsTo ngo:GenelSekreterlik {| ngo:legalBasis \"İnformal uygulama\" |} ."@tr ,
            "Superior unit to which this unit has reporting accountability. May differ from the hierarchical parent (ngo:subUnitOf). Local secretaries informally report to the General Secretariat; local treasurers to the General Treasury. Supports both formal and informal reporting links; context may be indicated via RDF-Star annotation.\nExample: ngo:KadikoySekreteri ngo:reportsTo ngo:GenelSekreterlik {| ngo:legalBasis \"Informal practice\" |} ."@en .

    ngo:isReportedToBy
        a owl:ObjectProperty ;
        owl:inverseOf ngo:reportsTo ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "raporlayan birim"@tr , "is reported to by"@en ;
        rdfs:comment
            "ngo:reportsTo'nun tersi. Bir birimin kendisine raporlayan birimleri verir. Reasoner tarafından otomatik çıkarılır.\nÖrnek: ngo:GenelSekreterlik ngo:isReportedToBy ngo:KadikoySekreteri ."@tr ,
            "Inverse of ngo:reportsTo. Returns units that report to a given unit. Inferred automatically by a reasoner.\nExample: ngo:GenelSekreterlik ngo:isReportedToBy ngo:KadikoySekreteri ."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  B. Bileşen Bağları
    # ══════════════════════════════════════════════════════════════════════════

    ngo:hasGoverningBody
        a owl:ObjectProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:GoverningBody ;
        rdfs:label   "kurulu"@tr , "has governing body"@en ;
        rdfs:comment
            "Bir NGO birimine bağlı resmi kurul veya meclisi belirtir. Bir birim birden fazla kurula sahip olabilir (örn. Yerel Meclis + Yerel Disiplin Kurulu). Kurul tipini ayırt etmek için rdfs:label veya ngo:Concept kullanın.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:hasGoverningBody ngo:KadikoyMeclisi , ngo:KadikoyDisiplinKurulu .\nngo:GenelMerkez ngo:hasGoverningBody ngo:MerkezYurutmeKurulu , ngo:PartiMeclisi , ngo:MerkezDisiplinKurulu ."@tr ,
            "Indicates a formal board or assembly attached to an NGO unit. A unit may have multiple governing bodies (e.g. Local Assembly + Local Disciplinary Board). Use rdfs:label or ngo:Concept to distinguish board types.\nExample: ngo:KadikoyIlceBaskanligi ngo:hasGoverningBody ngo:KadikoyMeclisi , ngo:KadikoyDisiplinKurulu .\nngo:GenelMerkez ngo:hasGoverningBody ngo:MerkezYurutmeKurulu , ngo:PartiMeclisi ."@en .

    ngo:governingBodyOf
        a owl:ObjectProperty ;
        owl:inverseOf ngo:hasGoverningBody ;
        rdfs:domain ngo:GoverningBody ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "kurulu olduğu birim"@tr , "governing body of"@en ;
        rdfs:comment
            "ngo:hasGoverningBody'nin tersi. Bir kurulun bağlı olduğu NGO birimini verir. Reasoner tarafından otomatik çıkarılır.\nÖrnek: ngo:KadikoyMeclisi ngo:governingBodyOf ngo:KadikoyIlceBaskanligi ."@tr ,
            "Inverse of ngo:hasGoverningBody. Returns the NGO unit to which a governing body is attached. Inferred automatically by a reasoner.\nExample: ngo:KadikoyMeclisi ngo:governingBodyOf ngo:KadikoyIlceBaskanligi ."@en .

    ngo:hasTaskUnit
        a owl:ObjectProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:TaskUnit ;
        rdfs:label   "görev birimi"@tr , "has task unit"@en ;
        rdfs:comment
            "Herhangi bir NGO birimine bağlı komisyon veya çalışma grubunu belirtir. Tüm NGO düzeylerinde geçerlidir: Genel Merkez düzeyinde bir ekonomi komisyonu, il düzeyinde bir tarım komisyonu vb.\nÖrnek: ngo:GenelMerkez ngo:hasTaskUnit ngo:MerkezEkonomiKomisyonu .\nngo:IstanbulIlBaskanligi ngo:hasTaskUnit ngo:IstanbulTarimKomisyonu ."@tr ,
            "Indicates a commission or working group attached to any NGO unit. Valid at all NGO levels: a central economy commission, a provincial agriculture commission, etc.\nExample: ngo:GenelMerkez ngo:hasTaskUnit ngo:MerkezEkonomiKomisyonu .\nngo:IstanbulIlBaskanligi ngo:hasTaskUnit ngo:IstanbulTarimKomisyonu ."@en .

    ngo:taskUnitOf
        a owl:ObjectProperty ;
        owl:inverseOf ngo:hasTaskUnit ;
        rdfs:domain ngo:TaskUnit ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "görev birimi olduğu birim"@tr , "task unit of"@en ;
        rdfs:comment
            "ngo:hasTaskUnit'in tersi. Bir görev biriminin bağlı olduğu NGO birimini verir. Reasoner tarafından otomatik çıkarılır.\nÖrnek: ngo:MerkezEkonomiKomisyonu ngo:taskUnitOf ngo:GenelMerkez ."@tr ,
            "Inverse of ngo:hasTaskUnit. Returns the NGO unit to which a task unit is attached. Inferred automatically by a reasoner.\nExample: ngo:MerkezEkonomiKomisyonu ngo:taskUnitOf ngo:GenelMerkez ."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  C. Coğrafi / İdari Bağlam
    # ══════════════════════════════════════════════════════════════════════════

    ngo:administrativeLevel
        a owl:ObjectProperty ;
        rdfs:domain ngo:TerritorialUnit ;
        rdfs:range  ngo:Concept ;
        rdfs:label   "idari kademe"@tr , "administrative level"@en ;
        rdfs:comment
            "Coğrafi teşkilat biriminin ülke idari hiyerarşisindeki kademesini belirten SKOS kavramı. Türkiye için İl, İlçe, Mahalle, Köy kademeleri; yurtdışı için Ülke, Eyalet, Oblast, Şehir, Semt gibi kademeler SKOS ile modellenir; OWL alt sınıfı açılmaz. SKOS kavramları NGO-vocabulary.trig dosyasında tanımlanır.\nÖrnek: ngo:IstanbulIlBaskanligi ngo:administrativeLevel ngo40:vpl3m7kx .  # ProvinceLevel\nngo:KadikoyIlceBaskanligi ngo:administrativeLevel ngo40:vdl8q2zn .  # DistrictLevel"@tr ,
            "SKOS concept indicating the territorial unit's level in the national administrative hierarchy. For Turkey: Province, District, Neighbourhood, Village; for abroad: Country, State, Oblast, City, Borough etc. modelled via SKOS, not OWL subclasses. SKOS concepts are defined in NGO-vocabulary.trig.\nExample: ngo:IstanbulIlBaskanligi ngo:administrativeLevel ngo40:vpl3m7kx .  # ProvinceLevel\nngo:KadikoyIlceBaskanligi ngo:administrativeLevel ngo40:vdl8q2zn .  # DistrictLevel"@en .

    ngo:administrativeArea
        a owl:ObjectProperty ;
        rdfs:domain ngo:TerritorialUnit ;
        rdfs:range  ngo:Concept ;
        rdfs:label   "idari bölge"@tr , "administrative area"@en ;
        rdfs:comment
            "Birimin teşkilatlandığı coğrafi idari alanı belirten ngo:Concept. Türkiye için il ve ilçe adları; yurtdışı için ülke ve eyalet/şehir adları ngo:Concept olarak modellenir (ngo:AdminAreaScheme). Bu sayede yabancı coğrafi yapılar OWL sınıfı açmadan temsil edilebilir.\nÖrnek: ngo:IstanbulIlBaskanligi ngo:administrativeArea ngo40:visp4k2w .  # IstanbulProvince\nngo:ABDTemsilciligi ngo:administrativeArea ngo40:vusd2z7m .  # UnitedStates"@tr ,
            "ngo:Concept indicating the geographic administrative area in which the unit is organised. Province and district names for Turkey; country and state/city names for abroad, all as ngo:Concept values (ngo:AdminAreaScheme). This allows foreign geographies to be represented without opening OWL subclasses.\nExample: ngo:IstanbulIlBaskanligi ngo:administrativeArea ngo40:visp4k2w .  # IstanbulProvince\nngo:ABDTemsilciligi ngo:administrativeArea ngo40:vusd2z7m .  # UnitedStates"@en .

    ngo:hasOfficer
        a owl:ObjectProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  ngo:Person ;
        rdfs:label   "görevli"@tr , "has officer"@en ;
        rdfs:comment
            "Bir NGO birimine atanmış görevliyi (başkan, sayman, sekreter, temsilci vb.) belirtir. Bir birimde birden fazla görevli olabilir. Görevin türü, başlangıç/bitiş tarihleri ve bitiş nedeni RDF-Star annotation ile taşınır (ngo:officerRole, ngo:startDate, ngo:endDate, ngo:endReason). Aynı (birim, kişi) çifti için birden fazla rol veya dönem söz konusuysa rdf:reifies explicit formu kullanılır.\nÖrnek: ngo40:dBSK ngo:hasOfficer ngo40:dpXXX {| ngo:officerRole ngo40:vorf4ilb ; ngo:startDate \"2024-01-01\"^^xsd:date |} ."@tr ,
            "Specifies an officer (president, treasurer, secretary, representative, etc.) assigned to an NGO unit. A unit may have more than one officer. Role type, start/end dates and end reason are carried via RDF-Star annotation (ngo:officerRole, ngo:startDate, ngo:endDate, ngo:endReason). When the same (unit, person) pair involves multiple roles or terms, the explicit rdf:reifies form is used.\nExample: ngo40:dBSK ngo:hasOfficer ngo40:dpXXX {| ngo:officerRole ngo40:vorf4ilb ; ngo:startDate \"2024-01-01\"^^xsd:date |} ."@en .

    ngo:officerOf
        a owl:ObjectProperty ;
        owl:inverseOf ngo:hasOfficer ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "görevli olduğu birim"@tr , "officer of"@en ;
        rdfs:comment
            "ngo:hasOfficer'ın tersi. Bir kişinin görevli olduğu NGO birimlerini verir. Bir kişi birden fazla birimde görev alabilir. Reasoner tarafından otomatik çıkarılır.\nÖrnek: ngo40:dpXXX ngo:officerOf ngo40:dBSK ."@tr ,
            "Inverse of ngo:hasOfficer. Returns the NGO units in which a person holds an officer role. A person may serve in more than one unit. Inferred automatically by a reasoner.\nExample: ngo40:dpXXX ngo:officerOf ngo40:dBSK ."@en .


###############################################################################
#  GRAPH 5 — Datatype Properties (7 adet)
###############################################################################

    ngo:unitCode
        a owl:DatatypeProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  xsd:string ;
        rdfs:label  "Birim Kodu"@tr , "Unit Code"@en ;
        rdfs:comment
            "NGO'nun iç kodlama sistemindeki benzersiz birim tanımlayıcısı. owl:hasKey ile birim kimliğinin belirlenmesinde kullanılır. Kod formatı kuruluşa özgüdür.\nÖrnek: ngo:IstanbulIlBaskanligi ngo:unitCode \"TR-34-IL\" ."@tr ,
            "Unique unit identifier in the NGO's internal coding system. Used for unit identification together with owl:hasKey. Code format is organisation-specific.\nExample: ngo:IstanbulIlBaskanligi ngo:unitCode \"TR-34-IL\" ."@en .

    ngo:foundingDate
        a owl:DatatypeProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  xsd:date ;
        rdfs:label  "Kuruluş Tarihi"@tr , "Founding Date"@en ;
        rdfs:comment
            "Birimin resmen kurulduğu tarih. Başkanlıklar için tüzel kişilik tescil tarihi; temsilcilikler için atama tarihi kullanılabilir.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:foundingDate \"2024-01-01\"^^xsd:date ."@tr ,
            "Date when the unit was formally established. For presidencies: legal registration date; for representations: appointment date may be used.\nExample: ngo:KadikoyIlceBaskanligi ngo:foundingDate \"2024-01-01\"^^xsd:date ."@en .

    ngo:dissolutionDate
        a owl:DatatypeProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  xsd:date ;
        rdfs:label  "Lağvedilme Tarihi"@tr , "Dissolution Date"@en ;
        rdfs:comment
            "Birimin resmen lağvedildiği tarih. Temsilciliğin Başkanlığa dönüşümünde temsilcilik kaydı için de kullanılır. Değer yoksa birim hâlâ aktif demektir.\nÖrnek: ngo:UmraniyeTemsilciligi ngo:dissolutionDate \"2024-06-30\"^^xsd:date ."@tr ,
            "Date when the unit was formally dissolved. Also used for representation records when converting to a presidency. Absent means the unit is still active.\nExample: ngo:UmraniyeTemsilciligi ngo:dissolutionDate \"2024-06-30\"^^xsd:date ."@en .

    ngo:legalRegNo
        a owl:DatatypeProperty ;
        rdfs:domain ngo:TerritorialUnit ;
        rdfs:range  xsd:string ;
        rdfs:label  "Tescil Numarası"@tr , "Legal Registration Number"@en ;
        rdfs:comment
            "Birimin ilgili makama tescil numarası. Yalnızca tüzel kişilikli (ngo:isLegalEntity true) TerritorialUnit kaynaklarında kullanılır.\nÖrnek: ngo40:dXXX ngo:legalRegNo \"34-NGO-2024-0108\" ."@tr ,
            "Legal registration number of the unit with the competent authority. Used only on TerritorialUnit resources with ngo:isLegalEntity true.\nExample: ngo40:dXXX ngo:legalRegNo \"34-NGO-2024-0108\" ."@en .

    ngo:legalJurisdiction
        a owl:DatatypeProperty ;
        rdfs:domain ngo:TerritorialUnit ;
        rdfs:range  xsd:string ;
        rdfs:label  "Yargı Çevresi"@tr , "Legal Jurisdiction"@en ;
        rdfs:comment
            "Başkanlığın tescilli olduğu hukuki yargı çevresi (ülke veya idari birim adı). Yurtdışı Başkanlıkları için yerel hukuktaki yargı adı kullanılır.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:legalJurisdiction \"Türkiye\" .\nngo:ABDNewyorkBaskanligi ngo:legalJurisdiction \"New York, USA\" ."@tr ,
            "Legal jurisdiction under which the presidency is registered (country or administrative unit name). For overseas presidencies, use the local law jurisdiction name.\nExample: ngo:KadikoyIlceBaskanligi ngo:legalJurisdiction \"Turkey\" .\nngo:ABDNewyorkBaskanligi ngo:legalJurisdiction \"New York, USA\" ."@en .

    ngo:addressText
        a owl:DatatypeProperty ;
        rdfs:domain ngo:NGOUnit ;
        rdfs:range  xsd:string ;
        rdfs:label  "Adres"@tr , "Address"@en ;
        rdfs:comment
            "Birimin serbest metin formatında adresi. Yapılandırılmış adres için vcard:Address kullanılabilir; bu property kolaylık amaçlıdır.\nÖrnek: ngo:KadikoyIlceBaskanligi ngo:addressText \"Moda Cad. No:42 Kadıköy / İstanbul\" ."@tr ,
            "Free-text address of the unit. For structured address, vcard:Address may be used; this property is for convenience.\nExample: ngo:KadikoyIlceBaskanligi ngo:addressText \"42 Moda St, Kadikoy / Istanbul\" ."@en .

    ngo:isPermanent
        a owl:DatatypeProperty ;
        rdfs:domain ngo:TaskUnit ;
        rdfs:range  xsd:boolean ;
        rdfs:label  "Kalıcı mı?"@tr , "Is Permanent?"@en ;
        rdfs:comment
            "Görev biriminin (komisyon veya çalışma grubu) kalıcı mı yoksa geçici mi olduğunu belirtir. Değer true ise birim süresiz aktif; false ise belirli bir görev veya dönem için kurulmuştur.\nÖrnek: ngo:MerkezEkonomiKomisyonu ngo:isPermanent true .\nngo:AnayasaCalismGrubu ngo:isPermanent false ."@tr ,
            "Indicates whether the task unit (commission or working group) is permanent or temporary. If true, the unit is active indefinitely; if false, it was formed for a specific task or period.\nExample: ngo:MerkezEkonomiKomisyonu ngo:isPermanent true .\nngo:AnayasaCalismGrubu ngo:isPermanent false ."@en .


###############################################################################
#  GRAPH 6 — Axioms
#  OWL kısıtları, property chain, disjointness, hasKey
###############################################################################

    # ── Property Chain: transitiveSubUnitOf ────────────────────────────────────
    #  Anlam: A subUnitOf B  ve  B transitiveSubUnitOf C  →  A transitiveSubUnitOf C
    #  TransitiveProperty ile birlikte tam geçişlilik sağlanır.

    ngo:transitiveSubUnitOf
        owl:propertyChainAxiom ( ngo:subUnitOf ngo:transitiveSubUnitOf ) .

    # ── hasKey: NGOUnit — unitCode ─────────────────────────────────────────────
    #  Aynı unitCode'a sahip iki farklı NGOUnit IRI'si aynı birime karşılık gelir.

    ngo:NGOUnit
        owl:hasKey ( ngo:unitCode ) .

    # ── Disjointness ──────────────────────────────────────────────────────────
    #  CoordinationZone, TerritorialUnit değildir (coğrafi birim saymaz).
    [] a owl:AllDisjointClasses ;
        owl:members ( ngo:CoordinationZone ngo:TerritorialUnit ) .


###############################################################################
#  GRAPH 7 — RDF-Star Kullanım Desenleri  (normatif belgeleme)
#  Gerçek bireyler ngog:ngo-yapi grafında yaşar.
###############################################################################

    # ── PATTERN 1: Temsilcilik Kapanışı + Yeni Başkanlık Kuruluşu ───────────────
    #
    #  Senaryo: Ümraniye Temsilciliği yeterli üye/bütçeye ulaştı.
    #  Temsilcilik kapatılır (dissolutionDate), ayrı IRI ile yeni Başkanlık kurulur.
    #  İki varlık hukuken farklıdır — aynı IRI üzerinde tip değiştirilmez.
    #
    #  # Eski Temsilcilik — kapatılır
    #  ngo40:dTEM a ngo:TerritorialUnit ;
    #      rdfs:label        "Ümraniye Temsilciliği"@tr ;
    #      ngo:isLegalEntity false ;
    #      ngo:foundingDate  "2023-01-01"^^xsd:date ;
    #      ngo:dissolutionDate "2023-12-31"^^xsd:date ;
    #      ngo:legalBasis    "Tüzük Md. 11 — Temsilcilik Kuruluşu" .
    #
    #  ngo40:dTEM ngo:hasOfficer ngo40:dpXXX {|
    #      ngo:officerRole ngo40:vorfdilt ;           # İl Temsilcisi
    #      ngo:startDate   "2023-01-01"^^xsd:date ;
    #      ngo:endDate     "2023-12-31"^^xsd:date ;
    #      ngo:endReason   ngo40:ver6cls3             # Kapanış
    #  |} .
    #
    #  # Yeni Başkanlık — ayrı IRI
    #  ngo40:dBSK a ngo:TerritorialUnit ;
    #      rdfs:label        "Ümraniye İlçe Başkanlığı"@tr ;
    #      ngo:isLegalEntity true ;
    #      ngo:foundingDate  "2024-01-01"^^xsd:date ;
    #      ngo:legalRegNo    "34-NGO-2024-0212" ;
    #      ngo:legalBasis    "Tüzük Md. 14 — İlçe Başkanlığı Kuruluşu" .

    # ── PATTERN 2: Koordinasyon Bölgesi Sorumlu Ataması ───────────────────────
    #
    #  Senaryo: Ahmet Yılmaz, Marmara Bölgesi'nden sorumlu kişi olarak atanmıştır.
    #  Sorumlu kişi ngo:hasOfficer ile, rolü ngo:officerRole annotation'ı ile belirtilir.
    #
    #  ngo40:dMARMARA ngo:hasOfficer ngo40:dpAhmet {|
    #      ngo:officerRole ngo40:vorfcblt ;           # Bölge Temsilcisi
    #      ngo:startDate   "2024-01-01"^^xsd:date
    #  |} .
    #
    #  Görevlisi olmayan bölgeler için yazışma dağıtımı:
    #  SPARQL OPTIONAL ile sorgulanır; görevli yoksa ngo:administrativeArea → iller doğrudan.

    # ── PATTERN 3: Hiyerarşik Bağın Tarihsel Belgesi ────────────────────────
    #
    #  Senaryo: Kadıköy birimi 2023'te farklı bir üst birime bağlıydı,
    #  2024'te İstanbul İl Başkanlığı'na aktarıldı.
    #
    #  _:h1 rdf:reifies <<( ngo:KadikoyBirimi ngo:subUnitOf ngo:EskiIlBirimi )>> ;
    #      ngo:startDate "2023-01-01"^^xsd:date ;
    #      ngo:endDate   "2023-12-31"^^xsd:date .
    #
    #  _:h2 rdf:reifies <<( ngo:KadikoyBirimi ngo:subUnitOf ngo:IstanbulIlBaskanligi )>> ;
    #      ngo:startDate "2024-01-01"^^xsd:date .
    #
    #  Güncel triple: ngo:KadikoyBirimi ngo:subUnitOf ngo:IstanbulIlBaskanligi .


###############################################################################
#  GRAPH 8 — SPARQL Integrity Constraints  (normatif kurallar)
###############################################################################

    # ── IC-01: transitiveSubUnitOf döngü içermemeli ────────────────────────────
    #
    #  ASK {
    #    ?unit ngo:transitiveSubUnitOf ?unit .
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-02: foundingDate ≤ dissolutionDate ─────────────────────────────────
    #
    #  ASK {
    #    ?unit ngo:foundingDate ?f ; ngo:dissolutionDate ?d .
    #    FILTER (?d < ?f)
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-03: RDF-Star dönemlerinde endDate ≥ startDate ─────────────────────
    #
    #  ASK {
    #    ?r ngo:startDate ?s ; ngo:endDate ?e .
    #    FILTER (?e < ?s)
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-04: Tüzel kişilikli TerritorialUnit en az bir GoverningBody içermeli ──
    #
    #  ASK {
    #    ?p a ngo:TerritorialUnit ; ngo:isLegalEntity true .
    #    FILTER NOT EXISTS { ?p ngo:hasGoverningBody ?gb }
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-05: CoordinationZone hiçbir zaman TerritorialUnit değil ─────────────
    #
    #  ASK {
    #    ?cz a ngo:CoordinationZone , ngo:TerritorialUnit .
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-09: Tüzel kişilikli TerritorialUnit başkan, sekreter, sayman içermeli ──
    #
    #  Her aktif (dissolutionDate yok) isLegalEntity=true birimde en az bir
    #  aktif (endDate yok) başkan, sekreter ve sayman görevlisi olmalıdır.
    #  (Üç ayrı ASK — biri başarısız olursa hangi rolün eksik olduğu görülür.)
    #
    #  # Başkan eksik mi?
    #  ASK {
    #    ?unit a ngo:TerritorialUnit ; ngo:isLegalEntity true .
    #    FILTER NOT EXISTS { ?unit ngo:dissolutionDate ?dd }
    #    FILTER NOT EXISTS {
    #      ?r rdf:reifies <<( ?unit ngo:hasOfficer ?p )>> ;
    #         ngo:officerRole ?rol .
    #      FILTER(?rol IN (ngo40:vorf1gnb, ngo40:vorf4ilb, ngo40:vorf7icb))
    #      FILTER NOT EXISTS { ?r ngo:endDate ?ed }
    #    }
    #  }
    #  → Sonuç boş olmalıdır.


###############################################################################
#  GRAPH 9 — NGO Vokabüler Profili
#  Dış SKOS ontolojisi yüklenmez. Bu grafta yalnızca projede fiilen kullanılan
#  SKOS class ve property'leri ngo: namespace'inde tanımlanır; rdfs:seeAlso ile
#  orijinal SKOS IRI'larına köprü kurulur.
###############################################################################

    # ── Sınıflar ─────────────────────────────────────────────────────────────

    ngo:ConceptScheme
        a owl:Class ;
        rdfs:label   "Kavram Şeması"@tr , "Concept Scheme"@en ;
        rdfs:comment
            "Belirli bir konuya ait NGO vokabüler kavramlarını bir araya getiren koleksiyon. NGO-vocabulary.trig dosyasındaki şemaların her biri bu sınıfın bir bireyi olarak modellenir.\nÖrnek: ngo:AdminLevelScheme a ngo:ConceptScheme ."@tr ,
            "Collection grouping NGO vocabulary concepts belonging to a particular subject. Each scheme in NGO-vocabulary.trig is an individual of this class.\nExample: ngo:AdminLevelScheme a ngo:ConceptScheme ."@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#ConceptScheme> .

    ngo:Concept
        a owl:Class ;
        rdfs:label   "Kavram"@tr , "Concept"@en ;
        rdfs:comment
            "Bir ngo:ConceptScheme içinde yer alan kontrollü vokabüler değeri. ngo:administrativeLevel, ngo:administrativeArea gibi property'lerin değer aralığını oluşturur.\nÖrnek: ngo40:vpl3m7kx a ngo:Concept .  # ProvinceLevel"@tr ,
            "Controlled vocabulary value belonging to a ngo:ConceptScheme. Forms the value range of properties such as ngo:administrativeLevel and ngo:administrativeArea.\nExample: ngo40:vpl3m7kx a ngo:Concept .  # ProvinceLevel"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#Concept> .

    # ── Şema Bağlantı Property'leri ──────────────────────────────────────────

    ngo:inScheme
        a owl:ObjectProperty ;
        rdfs:domain  ngo:Concept ;
        rdfs:range   ngo:ConceptScheme ;
        rdfs:label   "şema içinde"@tr , "in scheme"@en ;
        rdfs:comment
            "Kavramın ait olduğu ConceptScheme. Her kavram en az bir şemada yer almalıdır.\nÖrnek: ngo40:vpl3m7kx ngo:inScheme ngo:AdminLevelScheme .  # ProvinceLevel"@tr ,
            "The ConceptScheme to which this concept belongs. Every concept must belong to at least one scheme.\nExample: ngo40:vpl3m7kx ngo:inScheme ngo:AdminLevelScheme .  # ProvinceLevel"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#inScheme> .

    ngo:topConceptOf
        a owl:ObjectProperty ;
        owl:inverseOf ngo:hasTopConcept ;
        rdfs:domain  ngo:Concept ;
        rdfs:range   ngo:ConceptScheme ;
        rdfs:label   "üst kavramı olduğu şema"@tr , "top concept of"@en ;
        rdfs:comment
            "Kavramın şema hiyerarşisinin kökünde yer aldığını belirtir; daha geniş (ngo:broader) kavramı yoktur. ngo:hasTopConcept'in tersidir.\nÖrnek: ngo40:vcl5p9rt ngo:topConceptOf ngo:AdminLevelScheme .  # CountryLevel"@tr ,
            "Indicates that the concept sits at the root of the scheme hierarchy; it has no broader concept. Inverse of ngo:hasTopConcept.\nExample: ngo40:vcl5p9rt ngo:topConceptOf ngo:AdminLevelScheme .  # CountryLevel"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#topConceptOf> .

    ngo:hasTopConcept
        a owl:ObjectProperty ;
        owl:inverseOf ngo:topConceptOf ;
        rdfs:domain  ngo:ConceptScheme ;
        rdfs:range   ngo:Concept ;
        rdfs:label   "üst kavramı"@tr , "has top concept"@en ;
        rdfs:comment
            "Bir ConceptScheme'in hiyerarşik kök kavramlarını listeler. ngo:topConceptOf'un tersidir; reasoner tarafından otomatik çıkarılır.\nÖrnek: ngo:AdminLevelScheme ngo:hasTopConcept ngo40:vcl5p9rt .  # CountryLevel"@tr ,
            "Lists the root concepts of a ConceptScheme. Inverse of ngo:topConceptOf; inferred automatically by a reasoner.\nExample: ngo:AdminLevelScheme ngo:hasTopConcept ngo40:vcl5p9rt .  # CountryLevel"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#hasTopConcept> .

    # ── Hiyerarşi Property'leri ───────────────────────────────────────────────

    ngo:broader
        a owl:ObjectProperty ;
        owl:inverseOf ngo:narrower ;
        rdfs:domain  ngo:Concept ;
        rdfs:range   ngo:Concept ;
        rdfs:label   "daha geniş kavram"@tr , "broader"@en ;
        rdfs:comment
            "Bu kavramdan daha geniş kapsamlı olan üst kavrama bağ. Transitif değildir. ngo:narrower'ın tersidir.\nÖrnek: ngo40:vpl3m7kx ngo:broader ngo40:vcl5p9rt .  # ProvinceLevel → CountryLevel"@tr ,
            "Link to the concept with a broader scope. Non-transitive. Inverse of ngo:narrower.\nExample: ngo40:vpl3m7kx ngo:broader ngo40:vcl5p9rt .  # ProvinceLevel → CountryLevel"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#broader> .

    ngo:narrower
        a owl:ObjectProperty ;
        owl:inverseOf ngo:broader ;
        rdfs:domain  ngo:Concept ;
        rdfs:range   ngo:Concept ;
        rdfs:label   "daha dar kavram"@tr , "narrower"@en ;
        rdfs:comment
            "Bu kavramdan daha dar kapsamlı olan alt kavrama bağ. ngo:broader'ın tersidir; reasoner tarafından otomatik çıkarılır, veriye elle eklenmesi gerekmez.\nÖrnek: ngo40:vpl3m7kx ngo:narrower ngo40:vdl8q2zn .  # ProvinceLevel → DistrictLevel (reasoner ngo:broader'dan çıkarır)"@tr ,
            "Link to the concept with a narrower scope. Inverse of ngo:broader; inferred automatically by a reasoner, need not be asserted in data.\nExample: ngo40:vpl3m7kx ngo:narrower ngo40:vdl8q2zn .  # ProvinceLevel → DistrictLevel (inferred by reasoner from ngo:broader)"@en ;
        rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#narrower> .


###############################################################################
#  DEMAND-NGO-002 — Kişi / Üyelik Modeli
#  Aşağıdaki graflar DEMAND-NGO-001'deki örgütsel hiyerarşi modelini
#  kişi, üyelik, iletişim ve vokabüler kavram tipleriyle genişletir.
###############################################################################


###############################################################################
#  GRAPH 10 — Kişi Sınıfları  (DEMAND-NGO-002)
###############################################################################

    # ══════════════════════════════════════════════════════════════════════════
    #  A. Person — Tek sınıf + participationStatus property
    # ══════════════════════════════════════════════════════════════════════════

    ngo:Person
        a owl:Class ;
        rdfs:label   "Kişi"@tr , "Person"@en ;
        rdfs:comment
            "NGO ile herhangi bir ilişkisi olan kişiyi temsil eden tek sınıf. Resmi üye, gönüllü, aday gönüllü, aktif gönüllü ve takipçi arasındaki ayrım ngo:participationStatus property'si ile yapılır (OWL alt sınıflarıyla değil). Katılım durumu değiştiğinde (örn. aktif gönüllü → resmi üye) eski triple silinir, yeni eklenir; geçiş tarihi RDF-Star annotation ile izlenir.\nInstance URI formatı: ngo40:d[8-alfanümerik]"@tr ,
            "Single class representing any person with a relationship to the NGO. The distinction between official member, volunteer, candidate volunteer, active volunteer, and follower is expressed via ngo:participationStatus (not OWL subclasses). When status changes (e.g. active volunteer → official member) the old triple is deleted and a new one asserted; transition date is tracked via RDF-Star annotation.\nInstance IRI format: ngo40:d[8-alphanumeric]"@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  B. PostalAddress — Yapılandırılmış adres sınıfı
    # ══════════════════════════════════════════════════════════════════════════

    ngo:PostalAddress
        a owl:Class ;
        rdfs:label   "Posta Adresi"@tr , "Postal Address"@en ;
        rdfs:comment
            "Kişinin bir posta adresini temsil eden yapılandırılmış sınıf. Bir kişinin birden fazla adresi olabilir (iş, ev vb.). Adres tipi RDF-Star annotation ile ngo:addressType üzerinden belirtilir.\nÖrnek: ngo40:dXXX ngo:hasAddress ngo40:dYYY . ngo40:dYYY a ngo:PostalAddress ; ngo:streetAddress \"Moda Cad. No:5\" ; ngo:city ngo40:v[istanbul-iri] ."@tr ,
            "Structured class representing a postal address of a person. A person may have multiple addresses (work, home, etc.). Address type is indicated via RDF-Star annotation on ngo:addressType.\nExample: ngo40:dXXX ngo:hasAddress ngo40:dYYY . ngo40:dYYY a ngo:PostalAddress ; ngo:streetAddress \"Moda St No:5\" ; ngo:city ngo40:v[istanbul-iri] ."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  C. Typed Concept Subclasses — Kavram rol sınıfları
    #  Her biri ngo:Concept'in alt sınıfıdır; aynı kavram birden fazla
    #  alt sınıfta aynı anda yer alabilir (owl:disjoint yoktur).
    # ══════════════════════════════════════════════════════════════════════════

    ngo:ContributionConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Katkı Alanı Kavramı"@tr , "Contribution Concept"@en ;
        rdfs:comment
            "Bir kişinin NGO'ya gönüllü katkı vermek istediği alana karşılık gelen kavram. ngo:KatkiAlanlariScheme'de yer alır. Çok spesifik (Amasya'da ulaşım desteği) veya genel (Tarım politikası) olabilir; ngo:broader/narrower ile hiyerarşilenir. Bir kavram aynı anda hem ContributionConcept hem ExpertiseConcept veya ProfessionConcept olabilir."@tr ,
            "Concept representing an area in which a person wishes to contribute voluntarily to the NGO. Belongs to ngo:KatkiAlanlariScheme. May be very specific (transport support in Amasya) or general (Agricultural policy); hierarchised via ngo:broader/narrower. A concept may simultaneously be a ContributionConcept and an ExpertiseConcept or ProfessionConcept."@en .

    ngo:ExpertiseConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Uzmanlık Alanı Kavramı"@tr , "Expertise Concept"@en ;
        rdfs:comment
            "Kişinin uzman olduğu alana karşılık gelen kavram. ngo:UzmanlikAlanlariScheme'de yer alır. Kişi bu uzmanlığı fiilen kullanıyor olmak zorunda değildir ve bu alanda NGO'ya katkı vermek istemeyebilir (bkz. ngo:ContributionConcept farkı).\nÖrnek: Emekli bir psikiyatrist için uzmanlık alanı Psikiyatri olurken katkı alanı Tarım Ekonomisi olabilir."@tr ,
            "Concept representing a domain in which the person holds expertise. Belongs to ngo:UzmanlikAlanlariScheme. The person need not currently practice this expertise, nor wish to contribute to the NGO in this field (cf. ngo:ContributionConcept).\nExample: for a retired psychiatrist, expertise is Psychiatry while contribution area may be Agricultural Economics."@en .

    ngo:ProfessionConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Meslek Kavramı"@tr , "Profession Concept"@en ;
        rdfs:comment
            "Kişinin profesyonel olarak icra ettiği veya ettiği mesleğe karşılık gelen kavram. ngo:MesleklerScheme'de yer alır. Uzmanlık alanından bağımsızdır; aynı kavram her ikisinde de yer alabilir (ör. Ziraat Mühendisliği hem Meslek hem Uzmanlık olabilir)."@tr ,
            "Concept representing the profession the person practises or has practised professionally. Belongs to ngo:MesleklerScheme. Independent of expertise; the same concept may appear in both (e.g. Agricultural Engineering can be both Profession and Expertise)."@en .

    ngo:ParticipationStatusConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Katılım Durumu Kavramı"@tr , "Participation Status Concept"@en ;
        rdfs:comment
            "ngo:participationStatus property'sinin değer uzayını oluşturan kontrollü vokabüler kavramı. ngo:ParticipationStatusScheme'de tanımlanır. Olası değerler: OfficialMemberStatus, VolunteerStatus, ActiveVolunteerStatus, CandidateVolunteerStatus, FollowerStatus."@tr ,
            "Controlled vocabulary concept forming the value range of the ngo:participationStatus property. Defined in ngo:ParticipationStatusScheme. Possible values: OfficialMemberStatus, VolunteerStatus, ActiveVolunteerStatus, CandidateVolunteerStatus, FollowerStatus."@en .

    ngo:ContactStatusConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "İletişim Durumu Kavramı"@tr , "Contact Status Concept"@en ;
        rdfs:comment
            "RDF-Star iletişim triple'larına annotation olarak eklenen kontrollü vokabüler kavramı. ngo:ContactStatusScheme'de tanımlanır. Olası değerler: ContactActive, ContactInactive, ContactNotVeryActive."@tr ,
            "Controlled vocabulary concept added as RDF-Star annotation to contact triples. Defined in ngo:ContactStatusScheme. Possible values: ContactActive, ContactInactive, ContactNotVeryActive."@en .

    ngo:AddressTypeConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Adres Türü Kavramı"@tr , "Address Type Concept"@en ;
        rdfs:comment
            "RDF-Star adres triple'larına annotation olarak eklenen kontrollü vokabüler kavramı. ngo:AddressTypeScheme'de tanımlanır. Olası değerler: HomeAddress, WorkAddress, OtherAddress."@tr ,
            "Controlled vocabulary concept added as RDF-Star annotation to address triples. Defined in ngo:AddressTypeScheme. Possible values: HomeAddress, WorkAddress, OtherAddress."@en .

    ngo:OfficerRoleConcept
        a owl:Class ;
        rdfs:subClassOf ngo:Concept ;
        rdfs:label   "Görev Rolü Kavramı"@tr , "Officer Role Concept"@en ;
        rdfs:comment
            "ngo:officerRole annotation property'sinin değer uzayını oluşturan kontrollü vokabüler kavramı. ngo:OfficerRoleScheme'de tanımlanır. Genel Merkez, İl/İlçe Başkanlığı ve Temsilcilik rollerini kapsar (Genel Başkan, İl Saymanı, İlçe Temsilcisi vb.)."@tr ,
            "Controlled vocabulary concept forming the value range of the ngo:officerRole annotation property. Defined in ngo:OfficerRoleScheme. Covers Headquarter, Province/District Presidency and Representation roles (General President, Provincial Treasurer, District Representative, etc.)."@en .


###############################################################################
#  GRAPH 11 — Kişi Object Properties  (DEMAND-NGO-002)
###############################################################################

    # ══════════════════════════════════════════════════════════════════════════
    #  A. Katılım / Üyelik Bağları
    # ══════════════════════════════════════════════════════════════════════════

    ngo:participationStatus
        a owl:ObjectProperty , owl:FunctionalProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:ParticipationStatusConcept ;
        rdfs:label   "katılım durumu"@tr , "participation status"@en ;
        rdfs:comment
            "Kişinin NGO ile ilişkisinin mevcut türü. owl:FunctionalProperty: her kişinin en fazla bir durumu olabilir. Durum değişimlerinde eski triple silinir, yeni eklenir; RDF-Star annotation ile geçiş tarihi kaydedilir.\nDeğerler: ngo:ParticipationStatusScheme'deki kavramlar (OfficialMemberStatus, VolunteerStatus, ActiveVolunteerStatus, CandidateVolunteerStatus, FollowerStatus)."@tr ,
            "Current type of the person's relationship with the NGO. owl:FunctionalProperty: at most one status per person. On status change, old triple is deleted and new one asserted; transition date recorded via RDF-Star annotation.\nValues: concepts in ngo:ParticipationStatusScheme."@en .

    ngo:memberOf
        a owl:ObjectProperty , owl:FunctionalProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "üyesi olduğu birim"@tr , "member of"@en ;
        rdfs:comment
            "Resmi üyenin (OfficialMemberStatus) kayıtlı olduğu ilçe başkanlığı. owl:FunctionalProperty: her resmi üye tam olarak bir ilçe başkanlığına kayıtlıdır. SPARQL IC ile range'in ngo:TerritorialUnit (isLegalEntity true, DistrictLevel) olduğu doğrulanır.\nÖrnek: ngo40:d[kisi-iri] ngo:memberOf ngo40:d[ilce-iri] ."@tr ,
            "District presidency where the official member (OfficialMemberStatus) is registered. owl:FunctionalProperty: each official member is registered at exactly one district presidency. Validated via SPARQL IC that the range is ngo:TerritorialUnit (isLegalEntity true, DistrictLevel).\nExample: ngo40:d[person-iri] ngo:memberOf ngo40:d[district-iri] ."@en .

    ngo:pendingMemberOf
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "üye olacağı beklenen birim"@tr , "pending member of"@en ;
        rdfs:comment
            "Aktif gönüllünün (ActiveVolunteerStatus) ileride üye olmak istediği ilçe başkanlığı. İlçe kurulmamış olabilir (0..1). İlçe kurulduğunda bu property silinir, ngo:memberOf eklenir ve participationStatus güncellenir."@tr ,
            "District presidency where the active volunteer (ActiveVolunteerStatus) intends to become a member. The district may not yet exist (0..1). When the district is established this property is removed, ngo:memberOf is added, and participationStatus is updated."@en .

    ngo:affiliatedWith
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "bağlı olduğu birim"@tr , "affiliated with"@en ;
        rdfs:comment
            "Gönüllünün (VolunteerStatus veya ActiveVolunteerStatus) faaliyetlerine katıldığı NGO birimi. 0..* değer alabilir; birden fazla birimle ilişkilendirilebilir.\nÖrnek: ngo40:d[kisi-iri] ngo:affiliatedWith ngo40:d[istanbul-il-iri] ."@tr ,
            "NGO unit whose activities the volunteer (VolunteerStatus or ActiveVolunteerStatus) participates in. 0..* values allowed; may be associated with multiple units."@en .

    ngo:follows
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:NGOUnit ;
        rdfs:label   "takip ettiği birim"@tr , "follows"@en ;
        rdfs:comment
            "Takipçinin (FollowerStatus) takip ettiği NGO birimi. Üyelik veya gönüllülük içermez. 0..* değer alabilir."@tr ,
            "NGO unit followed by the person (FollowerStatus). Does not imply membership or volunteering. 0..* values allowed."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  B. Kişi → Kavram Bağları (Katkı, Uzmanlık, Meslek)
    # ══════════════════════════════════════════════════════════════════════════

    ngo:hasContributionArea
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:ContributionConcept ;
        rdfs:label   "katkı alanı"@tr , "has contribution area"@en ;
        rdfs:comment
            "Kişinin NGO'ya gönüllü katkı vermek istediği alan(lar). 0..* değer alır; SKOS broader/narrower ile hiyerarşik sorgulama desteklenir.\nÖrnek: ngo40:d[kisi] ngo:hasContributionArea ngo40:v[tarim-ekonomisi-iri] ."@tr ,
            "Area(s) in which the person wishes to contribute voluntarily to the NGO. 0..* values; hierarchical querying supported via SKOS broader/narrower."@en .

    ngo:hasExpertise
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:ExpertiseConcept ;
        rdfs:label   "uzmanlık alanı"@tr , "has expertise"@en ;
        rdfs:comment
            "Kişinin uzman olduğu alan(lar). ngo:hasContributionArea'dan bağımsızdır; kişi uzmanlığını kullanmak zorunda değildir. 0..* değer alır."@tr ,
            "Domain(s) in which the person holds expertise. Independent of ngo:hasContributionArea; the person need not use this expertise. 0..* values."@en .

    ngo:hasProfession
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:ProfessionConcept ;
        rdfs:label   "mesleği"@tr , "has profession"@en ;
        rdfs:comment
            "Kişinin profesyonel olarak icra ettiği veya ettiği meslek(ler). 0..* değer alır."@tr ,
            "Profession(s) the person practises or has practised professionally. 0..* values."@en .

    # ══════════════════════════════════════════════════════════════════════════
    #  C. İletişim Bağları
    # ══════════════════════════════════════════════════════════════════════════

    ngo:hasAddress
        a owl:ObjectProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  ngo:PostalAddress ;
        rdfs:label   "adresi"@tr , "has address"@en ;
        rdfs:comment
            "Kişinin posta adres(ler)ini belirtir. 0..* değer alır; her adres ayrı bir ngo:PostalAddress kaynağıdır. Adres türü RDF-Star annotation ile belirtilir.\nÖrnek: ngo40:d[kisi] ngo:hasAddress ngo40:d[adres] {| ngo:addressType ngo40:v[ev-adres-iri] |} ."@tr ,
            "Postal address(es) of the person. 0..* values; each address is a separate ngo:PostalAddress resource. Address type is indicated via RDF-Star annotation.\nExample: ngo40:d[person] ngo:hasAddress ngo40:d[addr] {| ngo:addressType ngo40:v[home-addr-iri] |} ."@en .

    ngo:city
        a owl:ObjectProperty ;
        rdfs:domain ngo:PostalAddress ;
        rdfs:range  ngo:Concept ;
        rdfs:label   "şehir / il"@tr , "city / province"@en ;
        rdfs:comment
            "Adresin bulunduğu il veya şehri belirten coğrafi alan kavramı. Değer ngo:AdminAreaScheme'deki bir kavramdır; yerler dönüşümünden sonra Türkiye illeri bu şemada yer alacaktır.\nÖrnek: ngo40:d[adres] ngo:city ngo40:v[istanbul-iri] ."@tr ,
            "Geographic area concept indicating the province or city of the address. Value is a concept in ngo:AdminAreaScheme; Turkish provinces will be present after the places conversion.\nExample: ngo40:d[addr] ngo:city ngo40:v[istanbul-iri] ."@en .


###############################################################################
#  GRAPH 12 — Kişi Datatype Properties  (DEMAND-NGO-002)
###############################################################################

    ngo:firstName
        a owl:DatatypeProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  xsd:string ;
        rdfs:label  "Adı"@tr , "First Name"@en ;
        rdfs:comment
            "Kişinin adı (verilen ad). Örnek: ngo40:d[kisi] ngo:firstName \"Ahmet\" ."@tr ,
            "Given name of the person. Example: ngo40:d[kisi] ngo:firstName \"Ahmet\" ."@en .

    ngo:familyName
        a owl:DatatypeProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  xsd:string ;
        rdfs:label  "Soyadı"@tr , "Family Name"@en ;
        rdfs:comment
            "Kişinin soyadı. Örnek: ngo40:d[kisi] ngo:familyName \"Yılmaz\" ."@tr ,
            "Family name (surname) of the person. Example: ngo40:d[kisi] ngo:familyName \"Yılmaz\" ."@en .

    ngo:phone
        a owl:DatatypeProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  xsd:string ;
        rdfs:label  "Telefon"@tr , "Phone"@en ;
        rdfs:comment
            "Kişinin telefon numarası. Birden fazla değer alabilir (iş, cep vb.). RDF-Star annotation ile durum ve not eklenebilir.\nÖrnek: ngo40:d[kisi] ngo:phone \"+90 555 001 0001\" {| ngo:contactStatus ngo40:v[aktif] ; ngo:contactNote \"22:00'den sonra aramayın\" |} ."@tr ,
            "Phone number of the person. Multiple values allowed (work, mobile, etc.). RDF-Star annotation may add status and note."@en .

    ngo:email
        a owl:DatatypeProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  xsd:string ;
        rdfs:label  "E-posta"@tr , "Email"@en ;
        rdfs:comment
            "Kişinin e-posta adresi. Birden fazla değer alabilir. RDF-Star annotation ile durum eklenebilir."@tr ,
            "Email address of the person. Multiple values allowed. RDF-Star annotation may add status."@en .

    ngo:twitterHandle
        a owl:DatatypeProperty ;
        rdfs:domain ngo:Person ;
        rdfs:range  xsd:string ;
        rdfs:label  "Twitter Hesabı"@tr , "Twitter Handle"@en ;
        rdfs:comment
            "Kişinin Twitter/X kullanıcı adı (@ dahil veya hariç). RDF-Star annotation ile aktivite durumu eklenebilir.\nÖrnek: ngo40:d[kisi] ngo:twitterHandle \"@ahmetyilmaz\" {| ngo:contactStatus ngo40:v[az-aktif] |} ."@tr ,
            "Twitter/X handle of the person (with or without @). RDF-Star annotation may add activity status."@en .

    ngo:streetAddress
        a owl:DatatypeProperty ;
        rdfs:domain ngo:PostalAddress ;
        rdfs:range  xsd:string ;
        rdfs:label  "Sokak Adresi"@tr , "Street Address"@en ;
        rdfs:comment
            "Posta adresinin cadde/sokak satırı.\nÖrnek: ngo40:d[adres] ngo:streetAddress \"Moda Cad. No:42\" ."@tr ,
            "Street line of the postal address."@en .

    ngo:postalDistrict
        a owl:DatatypeProperty ;
        rdfs:domain ngo:PostalAddress ;
        rdfs:range  xsd:string ;
        rdfs:label  "İlçe / Semt"@tr , "District / Borough"@en ;
        rdfs:comment
            "Posta adresinin ilçe veya semt bilgisi (serbest metin). Coğrafi birim bağı için ngo:city kullanın."@tr ,
            "District or borough of the postal address (free text). Use ngo:city for the geographic unit link."@en .

    ngo:postalCode
        a owl:DatatypeProperty ;
        rdfs:domain ngo:PostalAddress ;
        rdfs:range  xsd:string ;
        rdfs:label  "Posta Kodu"@tr , "Postal Code"@en ;
        rdfs:comment
            "Posta adresinin posta kodu.\nÖrnek: ngo40:d[adres] ngo:postalCode \"34710\" ."@tr ,
            "Postal code of the address."@en .


###############################################################################
#  GRAPH 13 — Kişi Annotation Properties  (DEMAND-NGO-002)
#  RDF-Star iletişim triple'larına annotation için kullanılır.
###############################################################################

    ngo:contactStatus
        a owl:AnnotationProperty ;
        rdfs:range  ngo:ContactStatusConcept ;
        rdfs:label  "İletişim Durumu"@tr , "Contact Status"@en ;
        rdfs:comment
            "İletişim triple'ına RDF-Star annotation olarak eklenen durum değeri. Değer ngo:ContactStatusScheme'deki bir kavramdır.\nÖrnek: ngo40:d[kisi] ngo:phone \"+90...\" {| ngo:contactStatus ngo40:v[aktif-iri] |} ."@tr ,
            "Status value added as RDF-Star annotation to a contact triple. Value is a concept in ngo:ContactStatusScheme."@en .

    ngo:contactNote
        a owl:AnnotationProperty ;
        rdfs:range  xsd:string ;
        rdfs:label  "İletişim Notu"@tr , "Contact Note"@en ;
        rdfs:comment
            "İletişim triple'ına RDF-Star annotation olarak eklenen serbest metin not.\nÖrnek: ngo40:d[kisi] ngo:phone \"+90...\" {| ngo:contactNote \"22:00'den sonra aramayın\" |} ."@tr ,
            "Free-text note added as RDF-Star annotation to a contact triple."@en .

    ngo:contactPriority
        a owl:AnnotationProperty ;
        rdfs:range  xsd:integer ;
        rdfs:label  "İletişim Önceliği"@tr , "Contact Priority"@en ;
        rdfs:comment
            "İletişim kanalının öncelik sırası (1 = birincil). RDF-Star annotation olarak kullanılır.\nÖrnek: ngo40:d[kisi] ngo:email \"...\" {| ngo:contactPriority 1 |} ."@tr ,
            "Priority order of the contact channel (1 = primary). Used as RDF-Star annotation."@en .

    ngo:addressType
        a owl:AnnotationProperty ;
        rdfs:range  ngo:AddressTypeConcept ;
        rdfs:label  "Adres Türü"@tr , "Address Type"@en ;
        rdfs:comment
            "Adres triple'ına RDF-Star annotation olarak eklenen adres türü. Değer ngo:AddressTypeScheme'deki bir kavramdır.\nÖrnek: ngo40:d[kisi] ngo:hasAddress ngo40:d[adres] {| ngo:addressType ngo40:v[ev-adresi-iri] |} ."@tr ,
            "Address type added as RDF-Star annotation to an address triple. Value is a concept in ngo:AddressTypeScheme."@en .


###############################################################################
#  GRAPH 14 — Kişi Model Axiomları  (DEMAND-NGO-002)
###############################################################################

    # ── hasKey: Person — firstName + familyName ───────────────────────────────
    #  Not: Person için güçlü bir doğal anahtar yoktur; gerçek sistemlerde
    #  ulusal kimlik veya sistem ID'si bu rolü üstlenir. Şimdilik ad+soyad
    #  bileşimi kısmi tekil kimlik sağlar; DEMAND-NGO-003'te gözden geçirilecektir.

    # ngo:Person owl:hasKey ( ngo:firstName ngo:familyName ) .  # ← opsiyonel, gerçek veriye göre karar verilecek

    # ── Concept Subclass Disjointness ─────────────────────────────────────────
    #  ContactStatusConcept, AddressTypeConcept ve ParticipationStatusConcept
    #  birbirinden ayrıktır (aynı kavram birden fazla operasyonel rolde olamaz).

    [] a owl:AllDisjointClasses ;
        owl:members (
            ngo:ParticipationStatusConcept
            ngo:ContactStatusConcept
            ngo:AddressTypeConcept
        ) .

    #  ContributionConcept, ExpertiseConcept, ProfessionConcept birbirinden
    #  AYRI DEĞİLDİR — aynı kavram birden fazla rolde bulunabilir.
    #  (ör. ZiraatMühendisliği hem ProfessionConcept hem ExpertiseConcept)


###############################################################################
#  GRAPH 15 — Kişi Model Integrity Constraints  (DEMAND-NGO-002)
###############################################################################

    # ── IC-06: OfficialMember → memberOf zorunlu ─────────────────────────────
    #
    #  ASK {
    #    ?p ngo:participationStatus ngo40:v[OfficialMemberStatus-iri] .
    #    FILTER NOT EXISTS { ?p ngo:memberOf ?unit }
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-07: memberOf range → TerritorialUnit (isLegalEntity true, DistrictLevel)
    #
    #  ASK {
    #    ?p ngo:memberOf ?unit .
    #    FILTER NOT EXISTS { ?unit a ngo:TerritorialUnit ; ngo:isLegalEntity true }
    #  }
    #  → Sonuç boş olmalıdır.

    # ── IC-08: Follower → memberOf olmamalı ──────────────────────────────────
    #
    #  ASK {
    #    ?p ngo:participationStatus ngo40:v[FollowerStatus-iri] ;
    #       ngo:memberOf ?unit .
    #  }
    #  → Sonuç boş olmalıdır.


###############################################################################
#  GRAPH 16 — RDF-Star Kullanım Desenleri  (DEMAND-NGO-002)
###############################################################################

    # ── PATTERN 5: İletişim Annotation ───────────────────────────────────────
    #
    #  Senaryo: Ahmet Yılmaz'ın telefonu aktif, Twitter hesabı az aktif.
    #
    #  ngo40:d[ahmet] ngo:phone  "+90 555 001 0001" .
    #  ngo40:d[ahmet] ngo:email  "ahmet@example.com" .
    #  ngo40:d[ahmet] ngo:twitterHandle "@ahmetyilmaz" .
    #
    #  ngo40:d[ahmet] ngo:phone "+90 555 001 0001" {|
    #      ngo:contactStatus   ngo40:v[aktif-iri] ;
    #      ngo:contactNote     "22:00'den sonra aramayın" ;
    #      ngo:contactPriority 1
    #  |} .
    #
    #  ngo40:d[ahmet] ngo:twitterHandle "@ahmetyilmaz" {|
    #      ngo:contactStatus ngo40:v[az-aktif-iri]
    #  |} .
    #
    #  Adres annotation:
    #  ngo40:d[ahmet] ngo:hasAddress ngo40:d[ahmet-adres] {|
    #      ngo:addressType ngo40:v[ev-iri]
    #  |} .

    # ── PATTERN 6: Katılım Durumu Geçişi ─────────────────────────────────────
    #
    #  Senaryo: Fatma aktif gönüllüyken Çankaya İlçe Başkanlığı kuruldu,
    #  resmi üye oldu.
    #
    #  # Eski durum silinir, yeni eklenir:
    #  # DELETE: ngo40:d[fatma] ngo:participationStatus ngo40:v[aktif-gonullu-iri]
    #  # ADD:    ngo40:d[fatma] ngo:participationStatus ngo40:v[resmi-uye-iri]
    #  #         ngo40:d[fatma] ngo:memberOf            ngo40:d[cankaya-ilce-iri]
    #
    #  Geçiş tarihi annotation:
    #  ngo40:d[fatma] ngo:participationStatus ngo40:v[resmi-uye-iri] {|
    #      ngo:since "2025-03-15"^^xsd:date ;
    #      ngo:notes "Çankaya İlçe Başkanlığı kuruluşuyla dönüşüm"
    #  |} .

}
