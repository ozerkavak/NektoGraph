{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "moduleResolution": "Node",
        "strict": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "declaration": true,
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@triplestore/core": [
                "../../lib_sources/quadstore-core/src/index.ts"
            ],
            "@triplestore/session": [
                "../session/src/index.ts"
            ]
        }
    },
    "include": [
        "src"
    ]
}
