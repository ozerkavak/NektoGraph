@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix : <http://www.40nodes.net/ontologies/ngo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.40nodes.net/ontologies/ngo/data/skos-data> {

    # --- Üyelik Seviyeleri Şeması ---
    :id_skosSCH001 a skos:ConceptScheme ; 
        rdfs:label "Membership Level Scheme"@en, "Üyelik Seviyesi Şeması"@tr .

    :id_skosLVL001 a skos:Concept ; 
        skos:inScheme :id_skosSCH001 ; 
        rdfs:label "Official"@en, "Resmi"@tr ;
        owl:differentFrom :id_skosLVL002 .

    :id_skosLVL002 a skos:Concept ; 
        skos:inScheme :id_skosSCH001 ; 
        rdfs:label "Unofficial"@en, "Gayrı-Resmi"@tr .

    # --- Bitiş Nedenleri Şeması ---
    :id_skosSCH002 a skos:ConceptScheme ; 
        rdfs:label "End Reason Scheme"@en, "Bitiş Nedeni Şeması"@tr .

    :id_skosEND001 a skos:Concept ; 
        skos:inScheme :id_skosSCH002 ; 
        rdfs:label "Neutral End"@en, "Nötr Bitiş"@tr .

    :id_skosEND002 a skos:Concept ; 
        skos:inScheme :id_skosSCH002 ; 
        rdfs:label "Voluntary End"@en, "Gönüllü Bitiş"@tr .

    :id_skosEND003 a skos:Concept ; 
        skos:inScheme :id_skosSCH002 ; 
        rdfs:label "Sanction End"@en, "Yaptırım Bitişi"@tr .

    # Alt Kavramlar (skos:broader hiyerarşisi korunmuştur)
    :id_skosEND004 a skos:Concept ; 
        skos:broader :id_skosEND001 ; 
        rdfs:label "Structural Upgrade"@en, "Birim Statü Yükselmesi"@tr .

    :id_skosEND005 a skos:Concept ; 
        skos:broader :id_skosEND001 ; 
        rdfs:label "Membership Type Change"@en, "Üyelik Tipi Değişikliği"@tr .

    :id_skosEND006 a skos:Concept ; 
        skos:broader :id_skosEND001 ; 
        rdfs:label "Death"@en, "Vefat"@tr .

    :id_skosEND007 a skos:Concept ; 
        skos:broader :id_skosEND002 ; 
        rdfs:label "Resignation"@en, "İstifa"@tr .
}